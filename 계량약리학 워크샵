        {c:"#94a3b8", t:"; (이소진 강사 실제 사례 기반)"},
        {c:"#86efac", t:"$SUBROUTINE ADVAN13 TOL=6"},
        {c:"#86efac", t:"$MODEL"},
        {c:"#86efac", t:"  COMP=(DEPOT1,   DEFDOSE)    ; CMT=1: 첫번째 흡수 경로"},
        {c:"#86efac", t:"  COMP=(DEPOT2)               ; CMT=2: 두번째 흡수 경로"},
