      </div>
      <div style={{display:"flex", gap:4, flexWrap:"wrap", marginBottom:12}}>
        {plots.map((pl,i)=>(
          <button key={i} onClick={()=>setActive(i)}
            style={{padding:"7px 12px", borderRadius:7, border:`1.5px solid ${active===i?pl.color:"#d1d5db"}`, background:active===i?pl.color:"#fff", color:active===i?"#fff":C.gray, fontWeight:700, fontSize:11, cursor:"pointer", fontFamily:"inherit"}}>
            {pl.name}
