    <Box title="ADVAN 선택 결론 — 실무 의사결정 요약" color={C.teal}>
      <CT headers={["모델 상황","첫 번째 시도","이유"]}
        colors={[C.teal, C.teal, C.teal]}
        rows={[
          ["탐색적 모델링 (속도 우선)",         "ADVAN4 TRANS4",     "가장 빠름. 표준 2-구획이면 충분"],
          ["최종 모델, 표준 경구 PK",             "ADVAN4 TRANS4",     "Gold Standard. 규제 친숙"],
          ["나중에 PD/Transit 추가 예정",         "ADVAN6 TOL=6",      "처음부터 $DES로 확장 기반 마련"],
          ["수렴 불안정 / Stiff ODE",             "ADVAN13 TOL=6",     "LSODA solver가 자동 안정화"],
          ["반감기 차이 극단 (>1000배)",           "ADVAN8 또는 ADVAN13","Gear solver 또는 LSODA"],
          ["선형이지만 구획 구조 복잡",            "ADVAN7",            "Rate Constant 자유 정의 가능"],
        ]}
      />
    </Box>
  </div>;
}

