        <div style={{display:"grid", gap:8}}>
          <div style={{background:"#fff", borderRadius:8, padding:"10px 12px", border:`1px solid ${p.color}22`}}>
            <div style={{fontWeight:700, color:p.color, fontSize:12, marginBottom:4}}>🎯 무엇을 보는가</div>
            <div style={{fontSize:12, lineHeight:1.7, color:C.gray}}>{p.what}</div>
          </div>
          <div style={{background:C.greenL, borderRadius:8, padding:"10px 12px"}}>
            <div style={{fontWeight:700, color:C.green, fontSize:12, marginBottom:4}}>✅ 이상적인 모습</div>
            <div style={{fontSize:12, lineHeight:1.7, color:C.green}}>{p.ideal}</div>
          </div>
          <div style={{background:C.redL, borderRadius:8, padding:"10px 12px"}}>
            <div style={{fontWeight:700, color:C.red, fontSize:12, marginBottom:4}}>🚨 문제 패턴 & 진단</div>
