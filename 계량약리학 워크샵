          ["$DES 문법",    "DADT(n) = ...",                    "DADT(n) = ... (완전히 동일)"],
          ["TOL",          "필수 (TOL=4~6)",                   "필수 (TOL=4~6, 동일)"],
          ["$MODEL",       "필수",                              "필수 (동일)"],
          ["일반 PK",      "빠름",                              "약간 느림 (overhead)"],
          ["Stiff ODE",    "불안정/느림",                       "★안정적+빠름"],
          ["TMDD",         "간혹 수렴 실패",                    "★표준 선택"],
