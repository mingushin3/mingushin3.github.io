// ── 5. $DES ───────────────────────────────────────────────
function DesSection() {
  return <div>
    <Box title="$DES 블록 — 미분방정식을 코드로 쓰는 방법" color={C.red}>
      <div style={{marginBottom:10}}>
        $DES는 각 구획에서 시간에 따른 약물 양의 변화를 미분방정식으로 기술하는 블록이다.
        <strong>물질 보존 법칙</strong>만 지키면 어떤 복잡한 관계도 표현할 수 있다.
      </div>
      <Box title="$DES 작성의 황금 원칙 — 구획 다이어그램을 먼저 그려라" color={C.red}>
        <div style={{background:C.redL, borderRadius:8, padding:"10px 12px", marginBottom:10}}>
          <div style={{fontFamily:"monospace", fontSize:12.5, lineHeight:2.2, textAlign:"center"}}>
            <div>{"DADT(n) = (구획 n으로 들어오는 흐름의 합) - (구획 n에서 나가는 흐름의 합)"}</div>
            <div style={{color:C.grayMid, fontSize:11}}>{"들어오면 +, 나가면 -, 각 흐름 = 속도상수 x 약물량"}</div>
          </div>
        </div>
        <CT headers={["흐름 유형", "수식 (DADT에서)", "예시"]}
          colors={[C.red, C.red, C.red]}
          rows={[
            ["구획 1->2 이동 (1에서 나감)", "-K12 * A(1)", "depot에서 중심으로 흡수"],
            ["구획 1->2 이동 (2로 들어옴)", "+K12 * A(1)", "위와 동일, 2번 구획 입장"],
            ["구획 1에서 소멸",             "-K10 * A(1)", "CL/V 제거"],
            ["비선형 제거 (MM)",            "-Vmax*C/(Km+C)", "Michaelis-Menten"],
            ["고정 속도 유입",              "+INPUT(t)",   "지속 주입, 생성"],
          ]}
        />
      </Box>
    </Box>

    <Acc title="$DES 예시 1 — 경구 2-구획 (선형 퍼스트 오더)" color={C.green}>
      <Code lines={[
        {c:"#94a3b8", t:"; 경구 투여, 2-구획 (ADVAN4와 동일한 모델)"},
        {c:"#94a3b8", t:"; CMT=1: Depot, CMT=2: Central, CMT=3: Peripheral"},
        {c:"#fbbf24", t:"$DES"},
        {c:"#86efac", t:"  ; Depot 구획: 흡수로만 나감"},
        {c:"#86efac", t:"  DADT(1) = -KA * A(1)"},
        {c:"",        t:""},
        {c:"#86efac", t:"  ; Central 구획: depot에서 들어오고, 제거+말초 분포로 나감"},
        {c:"#86efac", t:"  DADT(2) = KA*A(1) - (CL+Q)/V2*A(2) + Q/V3*A(3)"},
        {c:"",        t:""},
        {c:"#86efac", t:"  ; Peripheral 구획: central에서 들어오고 central로만 나감"},
        {c:"#86efac", t:"  DADT(3) = Q/V2*A(2) - Q/V3*A(3)"},
      ]}/>
    </Acc>

    <Acc title="$DES 예시 2 — 비선형 (Michaelis-Menten) 제거" color={C.red}>
      <Code lines={[
        {c:"#94a3b8", t:"; MM 제거: 포화 가능한 제거 (예: 간 대사 포화)"},
        {c:"#94a3b8", t:"; CMT=1: Central (IV 투여), 1-구획"},
        {c:"#fbbf24", t:"$DES"},
        {c:"#86efac", t:"  C   = A(1) / V            ; 현재 농도 계산"},
        {c:"#86efac", t:"  MM  = Vmax * C / (Km + C)  ; MM 속도"},
        {c:"",        t:""},
        {c:"#86efac", t:"  DADT(1) = -MM - CL_lin/V * A(1) ; MM + 선형 제거 병행"},
        {c:"",        t:""},
        {c:"#94a3b8", t:"; Vmax: 최대 제거 속도 (mg/hr)"},
        {c:"#94a3b8", t:"; Km:   MM 상수 (농도 단위, ng/mL)"},
        {c:"#94a3b8", t:"; CL_lin: 선형 경로 Clearance (신배설 등)"},
      ]}/>
      <Warn>{"Km의 단위가 중요하다: ADVAN10의 KM은 Amount 단위이지만, $DES에서 직접 쓸 때는 Concentration(농도) 단위를 사용한다. 혼동하면 Vmax/Km 비율이 완전히 틀린 값이 된다."}</Warn>
    </Acc>

    <Acc title="$DES 예시 3 — Effect Compartment (PK/PD 연결)" color={C.purple}>
      <Code lines={[
        {c:"#94a3b8", t:"; Effect Compartment: ke0로 PK->PD 연결"},
        {c:"#94a3b8", t:"; CMT=1: Central (IV), CMT=2: Effect compartment"},
        {c:"#fbbf24", t:"$DES"},
        {c:"#86efac", t:"  ; Central 구획"},
        {c:"#86efac", t:"  DADT(1) = -CL/V1 * A(1) - Q/V1*A(1) + Q/V2_p*A(2_p)"},
        {c:"",        t:""},
        {c:"#86efac", t:"  ; Effect compartment: ke0 속도로 equilibrium (양이 아닌 농도 개념)"},
        {c:"#86efac", t:"  Ce = A(2) / Ve            ; Effect site 농도"},
        {c:"#86efac", t:"  Cp = A(1) / V1            ; Plasma 농도"},
        {c:"#86efac", t:"  DADT(2) = ke0 * (Cp - Ce) * Ve ; 혈장과 effect site 평형"},
        {c:"",        t:""},
        {c:"#f9a8d4", t:"$ERROR"},
        {c:"#f9a8d4", t:"  Ce_obs = A(2) / Ve        ; effect site 농도"},
        {c:"#f9a8d4", t:"  EFFECT = Emax * Ce_obs / (EC50 + Ce_obs)  ; Emax 모델"},
        {c:"#f9a8d4", t:"  Y = EFFECT * (1 + EPS(1)) + EPS(2)"},
      ]}/>
      <Gem>{"ke0(Effect site equilibration rate)는 혈장과 효과 부위 사이의 평형 속도다. ke0가 클수록 혈장-효과 부위 히스테리시스가 작아진다. 혈장 농도(Cp)와 효과(E) 사이에 시간 지연이 관찰되면 Effect Compartment 모델이 필요하다."}</Gem>
    </Acc>

    <Acc title="$DES의 특수 문법 — 시간 변수 T 사용법" color={C.amber}>
      <Box title="T vs TIME — $DES 안에서의 시간 참조" color={C.amber}>
        <CT headers={["변수", "의미", "사용 상황"]}
          colors={[C.amber, C.amber, C.amber]}
          rows={[
            ["T",    "$DES 블록 내에서 현재 시간을 나타내는 변수",  "DADT 식 안에서 시간을 포함해야 할 때"],
            ["TIME", "$PK 블록에서 사용하는 시간 변수 (상수 취급)","DADT 식 안에 쓰면 미분되지 않아 오류"],
          ]}
        />
        <Code lines={[
          {c:"#94a3b8", t:"; 시간에 따라 변하는 약물 투입 (시간적 유입) 예시"},
