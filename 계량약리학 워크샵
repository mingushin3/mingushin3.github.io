          {c:"#86efac", t:"$THETA  (0, 0.2) ; THETA(5): 비례 오차 ~20%"},
          {c:"#86efac", t:"$SIGMA  1 FIX    ; EPS=1로 고정"},
        ]}/>
      </Acc>
    </Box>
  </div>;
}

