      <div style={{fontSize:12.5, lineHeight:1.75, marginBottom:10}}>
        GAM은 "어떤 공변량이 어떤 PK 파라미터를 얼마나 잘 설명하는가"를 AIC로 순위 매기는 자동 탐색 방법이다. 시각적 스크리닝의 주관성을 보완한다.
      </div>
      <div style={{background:C.purpleL, border:`1px solid #c4b5fd`, borderRadius:8, padding:"10px 12px", marginBottom:10}}>
        <div style={{fontWeight:800, color:C.purple, fontSize:12.5, marginBottom:6}}>GAM 동작 원리 (AIC 기반 Forward Stepwise)</div>
        <div style={{fontSize:12, color:C.purple, lineHeight:1.9}}>
          1. 베이스: ETA ~ 1 (공변량 없음) → AIC 기록<br/>
          2. 각 공변량 하나씩 추가: ETA ~ CLCR, ETA ~ WT, ... → AIC 비교<br/>
          3. AIC 가장 많이 감소시킨 공변량 첫 번째 선택<br/>
          4. 선택된 공변량 고정 + 나머지 하나씩 추가 → AIC 반복<br/>
          5. 더 이상 AIC 감소 없을 때까지 → 최종 선택 목록 출력
        </div>
      </div>
      <Code lines={[
        {c:"#94a3b8", t:"# GAM 예시 결과 해석 (CL에 대한 스크리닝)"},
        {c:"",        t:""},
        {c:"#c4b5fd", t:"Start: AIC = 509  (공변량 없음)"},
        {c:"#86efac", t:"  + CLCR:  AIC = 467  (ΔAIC = -42  ★ 가장 큰 감소)"},
        {c:"#c4b5fd", t:"  + WT:    AIC = 495  (ΔAIC = -14)"},
        {c:"#c4b5fd", t:"  + AGE:   AIC = 508  (ΔAIC = -1,  유의하지 않음)"},
        {c:"",        t:""},
        {c:"#fbbf24", t:"→ CLCR 채택. 다음 단계: CLCR 고정 후 나머지 추가 시도"},
        {c:"",        t:""},
        {c:"#86efac", t:"Start: AIC = 467  (CLCR 고정)"},
        {c:"#86efac", t:"  + AGE:  AIC = 462  (ΔAIC = -5  추가 감소 ✓)"},
        {c:"#c4b5fd", t:"  + WT:   AIC = 469  (ΔAIC = +2  ← CLCR과 공선! 오히려 나빠짐)"},
        {c:"",        t:""},
        {c:"#fbbf24", t:"→ CLCR + AGE 채택. WT는 CLCR이 이미 설명함 (공선성 시각화)"},
      ]}/>
      <CT headers={["AIC 변화","해석","GAM 결론"]}
        colors={[C.purple, C.slate, C.green]}
        rows={[
          ["ΔAIC 크게 감소 (> 5)","유의한 설명력 추가","강력한 후보 → NONMEM 검증 필수"],
          ["ΔAIC 소폭 감소 (1~5)","경계선적","임상 관련성 고려 후 NONMEM 검증"],
          ["ΔAIC ≈ 0","추가 설명력 없음","제외 고려"],
          ["ΔAIC > 0 (AIC 증가)","오히려 나빠짐","명확히 제외"],
        ]}
      />
      <Expert>{"GAM은 순수 수치적 접근이므로 기전 근거 없이 통계적으로만 유의한 공변량을 선택할 위험이 있다. GAM 결과는 '탐색의 출발점'이며, 최종 공변량 선택은 반드시 ① 기계론적 타당성 ② NONMEM에서 OFV/ω² 변화 검증 ③ 임상적 의미로 재확인해야 한다."}</Expert>
    </Box>
  </div>;
}

function CriteriaSection() {
  return <div>
    <Box title="타당한 공변량의 3가지 판단 기준 — 셋 다 충족해야 한다" color={C.green}>
      <Acc title="기준 ①: OFV의 유의한 감소 — LRT(Likelihood Ratio Test) 기반" color={C.blue}>
        <div style={{fontSize:12, lineHeight:1.75, marginBottom:8}}>
          추가되는 세타(θ) 수에 따라 χ² 분포의 임계값이 달라진다.
        </div>
        <CT headers={["추가 θ수 (df)","ΔOFV 기준 (p=0.05)","ΔOFV 기준 (p=0.01)","적용 상황"]}
          colors={[C.blue, C.green, C.amber, C.slate]}
          rows={[
            ["df=1","> 3.84","> 6.63","기울기 1개 추가 (선형 공변량)"],
            ["df=2","> 5.99","> 9.21","절편+기울기 2개, 또는 범주 3개"],
            ["df=3","> 7.81","> 11.35","복합 공변량 구조"],
          ]}
        />
        <div style={{background:"#eff6ff", borderRadius:7, padding:"8px 10px", fontSize:11.5, color:C.blue, lineHeight:1.7}}>
          <strong>Forward Selection</strong>: p=0.05 기준 → ΔOFV &gt; 3.84 (df=1)<br/>
          <strong>Backward Elimination</strong>: p=0.01 더 엄격 → ΔOFV &gt; 6.63 (df=1)<br/>
          → 비대칭 기준: 관대하게 들어오게 하고(실제 공변량 놓치지 않도록), 엄격하게 제거한다(불필요한 것 정리).
        </div>
      </Acc>
      <Acc title="기준 ②: 해당 파라미터 ω²의 감소" color={C.green}>
        <div style={{fontSize:12, lineHeight:1.75, marginBottom:6}}>
          공변량이 추가된 파라미터의 η에 해당하는 ω²이 감소해야 한다. OFV만 줄고 ω²가 안 줄면 그 공변량이 진짜 원인이 아닐 가능성이 있다.
        </div>
        <Code lines={[
          {c:"#94a3b8", t:"; 베이스 모델 vs 공변량 모델 비교"},
          {c:"#c4b5fd", t:"베이스:  OMEGA(1,1) = 0.25  → %CV ≈ 51%"},
          {c:"#86efac", t:"WT 추가: OMEGA(1,1) = 0.08  → %CV ≈ 29%  ← 감소 확인"},
          {c:"#94a3b8", t:"; 권고: 최소 20~30% 이상 감소해야 의미 있다고 볼 수 있음"},
          {c:"#94a3b8", t:"; 감소 폭이 클수록 그 공변량이 BSV를 잘 설명함"},
        ]}/>
      </Acc>
      <Acc title="기준 ③: 잔차 오차(RUV, σ²)의 증가 없음" color={C.red}>
        <div style={{fontSize:12, lineHeight:1.75, marginBottom:6}}>
          공변량 추가 후 σ²가 크게 증가하면 잘못된 공변량이 반영된 것이다.
        </div>
        <div style={{background:C.orangeL, border:`1px solid #fed7aa`, borderRadius:7, padding:"8px 10px", fontSize:11.5, color:C.orange, lineHeight:1.8, marginBottom:6}}>
          <strong>투석환자 사례:</strong><br/>
          비투석군: CL ∝ CrCL (신기능 비례)<br/>
          투석군: CL ∝ 투석 제거 속도 (CrCL과 무관)<br/>
          → 두 그룹 합쳐 CrCL만 공변량으로 쓰면 투석군 예측 실패<br/>
          → σ²(잔차)가 폭발적으로 증가<br/>
          → 해결: DIAL(0/1) 범주형 공변량으로 그룹 먼저 분리
        </div>
        <Gem>{"3개 기준 요약: ①OFV(통계적 기준) + ②ω²(기계론적 설명력) + ③RUV(모델 구조 안정성). 셋을 동시에 만족하는 공변량이 진정한 공변량이다. 데이터가 크면 작은 차이도 ΔOFV>3.84가 되므로 ②ω² 감소 확인이 더욱 중요해진다."}</Gem>
      </Acc>
    </Box>
  </div>;
}

function StructureSection() {
  return <div>
    <Box title="공변량 구조(Structure) 선택 — 어떤 수식으로 관계를 표현할 것인가" color={C.indigo}>
      <CT headers={["구조 유형","수식","NONMEM 코드","적용 상황"]}
        colors={[C.indigo, C.slate, C.green, C.amber]}
        rows={[
          ["선형 (centered)","CL = (θ_slope×WT + θ_int) × exp(η)","CL=(THETA(3)*WT+THETA(1))*EXP(ETA(1))","WT 전 범위에서 선형 관계. 해석 용이하나 음수 가능성 주의"],
          ["비례 스케일링","V = θ_V × (WT/70) × exp(η)","V=THETA(2)*(WT/70)*EXP(ETA(2))","WT=0 → V=0 가정. 체중 전용. 세타 수 절약. 해석 직관적"],
          ["파워 모델 ★권장","V = θ_V × (WT/70)^θ_power × exp(η)","V=THETA(2)*(WT/70)**THETA(6)*EXP(ETA(2))","가장 유연. power=1이면 선형, <1이면 체감. 소아 외삽에 필수"],
          ["지수 모델","CL = θ_CL × exp(θ_eff×CrCL) × exp(η)","CL=THETA(1)*EXP(THETA(5)*CLCR)*EXP(ETA(1))","공변량 범위 넓을 때. CL이 항상 양수 보장"],
          ["구간 선형 (Piecewise)","구간별 서로 다른 기울기","IF(WT.LT.70)… ELSE…","꺾이는 패턴 관찰 시만. 임상적 컷포인트 필요"],
          ["범주형 효과","CL = θ_CL × θ_sex_f (SEX=2일 때)","FEFF=1; IF(SEX.EQ.2) FEFF=THETA(7)","성별, 유전형 등. θ가 비율(0.7이면 30% 감소)"],
        ]}
      />
    </Box>

    <Box title="파워 모델 (Allometric Scaling) — 계량약리학의 황금 공변량 구조" color={C.indigo}>
      <div style={{fontSize:12.5, lineHeight:1.75, marginBottom:8}}>
        파워 모델은 Kleiber's Law에 기반한 생리학적으로 타당한 구조다: 대사율 ∝ 체중^0.75.
      </div>
      <Code lines={[
        {c:"#94a3b8", t:"; 알로메트릭 스케일링 표준 코드 (NONMEM)"},
        {c:"#86efac", t:"CL = THETA(1) * (WT/70)**0.75 * EXP(ETA(1))  ; 고정 지수"},
        {c:"#86efac", t:"V  = THETA(2) * (WT/70)**1.0  * EXP(ETA(2))  ; 고정 지수"},
        {c:"",        t:""},
        {c:"#94a3b8", t:"; 지수를 추정하는 방법 (데이터 충분 시)"},
        {c:"#fbbf24", t:"CL = THETA(1) * (WT/70)**THETA(5) * EXP(ETA(1))"},
        {c:"#fbbf24", t:"V  = THETA(2) * (WT/70)**THETA(6) * EXP(ETA(2))"},
        {c:"#94a3b8", t:"; THETA(5) 초기값 = 0.75, THETA(6) 초기값 = 1.0"},
      ]}/>
      <CT headers={["파라미터","이론 지수","생물학적 근거","실무"]}
        colors={[C.indigo, C.green, C.slate, C.amber]}
        rows={[
          ["CL (청소율)","0.75","대사율 ∝ WT^0.75 (Kleiber)","소아→성인 외삽 필수"],
          ["V (분포 용적)","1.0","체액량 ∝ WT^1.0 (직선 비례)","신생아→성인 항상 1.0 고정"],
          ["Q (구획간 CL)","0.75","CL과 동일 생리학","혈류 기반"],
          ["t½ (반감기)","V/CL ∝ WT^0.25","WT^1.0 / WT^0.75 = WT^0.25","몸이 클수록 t½ 길어지는 이유"],
        ]}
      />
      <Expert>{"알로메트릭 지수를 고정할 것인가 추정할 것인가: 규제 제출에서는 이론적 지수(0.75, 1.0)를 고정하고 데이터와 일치하지 않는지 검증한다. 소아 대상 연구에서 allometric scaling이 필수적인 이유는 성인 모델에서 소아로 외삽할 때 기전적으로 정당화된 유일한 방법이기 때문이다."}</Expert>
    </Box>

    <Box title="센터링(Centering) — θ의 해석을 명확하게 만든다" color={C.indigo}>
      <CT headers={["센터링 전 (WT 직접 투입)","센터링 후 (WT/70 또는 WT-70)","차이"]}
        colors={[C.red, C.green, C.slate]}
        rows={[
          ["θ_intercept = WT=0일 때 CL → 생물학적 의미 없음","θ_CL = 70kg 표준 환자의 CL → 직관적 해석","센터링 후 θ가 표준 환자 기준값으로 의미를 가짐"],
          ["초기값 설정 어려움","초기값 = NCA CL 추정값 그대로 사용 가능","모델 수렴 안정성 향상"],
        ]}
      />
    </Box>
  </div>;
}

function StepwiseSection() {
  return <div>
    <Box title="Forward Selection & Backward Elimination — SCM 표준 절차" color={C.orange}>
      <div style={{display:"flex", flexDirection:"column", gap:6, marginBottom:10}}>
        <div style={{background:C.orangeL, border:`1px solid #fdba74`, borderRadius:8, padding:"12px"}}>
