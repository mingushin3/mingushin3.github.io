          ["ADVAN2", "1-구획", "경구/EV",  "2",  "TRANS1/2", "K,KA(or CL,V,KA)"],
          ["ADVAN3", "2-구획", "IV",       "2",  "TRANS1/3/4/5", "K10,K12,K21(or CL,V1,Q,V2)"],
          ["ADVAN4", "2-구획", "경구/EV ★","3",  "TRANS1/3/4/5", "K,KA,K23,K32(or CL,V2,Q,V3,KA)"],
          ["ADVAN10","1-구획 MM제거","IV", "1",  "TRANS1",   "VM,KM (Amount 단위 주의!)"],
          ["ADVAN11","3-구획", "IV",       "3",  "TRANS1/4/5","CL,V1,Q2,V2,Q3,V3"],
          ["ADVAN12","3-구획", "경구/EV",  "4",  "TRANS1/4/5","CL,V2,Q3,V3,Q4,V4,KA"],
        ]}
      />
      <Warn>{"ADVAN10의 KM은 concentration 단위가 아닌 Amount(질량) 단위다. KM = Km_conc x V. 이것을 모르고 문헌의 Km(농도 단위)을 그대로 초기값으로 넣으면 완전히 틀린 추정이 된다."}</Warn>
    </Box>

    <Box title="TRANS 옵션 — 파라미터 표현 방식 선택" color={C.green}>
      <CT headers={["TRANS", "파라미터 표현 방식", "특징", "실무 선호"]}
        colors={[C.slate, C.green, C.green, C.amber]}
        rows={[
          ["TRANS1","Micro rate constants (K10, K12, K21...)", "수학적 기본. 해석 어려움", "비추천"],
          ["TRANS2","CL, V (1-구획용)", "임상적으로 직관적", "ADVAN1/2 표준"],
          ["TRANS3","CL, V1, Q, V2 + K 혼합", "비선형 확장 가능", "드묾"],
          ["TRANS4","CL, V1, Q, V2 (2-구획용) ★", "가장 직관적, 규제 보고 표준", "★ADVAN3/4 표준"],
          ["TRANS5","CL, V1, Q2, V2, Q3, V3 (3-구획용)", "3-구획 직관적", "ADVAN11/12"],
        ]}
      />
      <Gem>{"실무 표준: ADVAN4 + TRANS4 = 경구 2-구획. CL, V2, Q, V3, KA로 파라미터 추정. 이 조합이 임상 PopPK의 가장 흔한 모델이다. TRANS4를 쓰면 레이트 상수(K10, K12)가 아닌 CL/V로 결과가 나오므로 임상 해석과 규제 보고가 훨씬 쉽다."}</Gem>
    </Box>

    <Acc title="ADVAN4 + TRANS4 완전 코드 — 경구 2-구획 (임상 표준)" color={C.green}>
      <Code lines={[
        {c:"#94a3b8", t:"; ADVAN4 + TRANS4: 경구 2-구획 PopPK 표준 코드"},
        {c:"#86efac", t:"$SUBROUTINE ADVAN4 TRANS4"},
        {c:"",        t:""},
        {c:"#c4b5fd", t:"$PK"},
        {c:"#c4b5fd", t:"  ; 공변량 포함 파라미터 정의"},
        {c:"#c4b5fd", t:"  TVCL = THETA(1) * (WT/70)**0.75 * (CRCL/90)**THETA(6)"},
        {c:"#c4b5fd", t:"  TVV2 = THETA(2) * (WT/70)**1.0"},
        {c:"#c4b5fd", t:"  CL   = TVCL * EXP(ETA(1))    ; IIV on CL"},
        {c:"#c4b5fd", t:"  V2   = TVV2 * EXP(ETA(2))    ; IIV on V2"},
        {c:"#c4b5fd", t:"  Q    = THETA(3)               ; Q (intercompartmental)"},
        {c:"#c4b5fd", t:"  V3   = THETA(4)               ; V3 (peripheral)"},
        {c:"#c4b5fd", t:"  KA   = THETA(5) * EXP(ETA(3)) ; IIV on KA"},
        {c:"#c4b5fd", t:"  S2   = V2 / 1000              ; scaling: mg/L -> ug/L"},
        {c:"",        t:""},
        {c:"#94a3b8", t:"; ADVAN4의 구획 번호 (CMT 매핑)"},
        {c:"#94a3b8", t:"; CMT=1: Depot (투여 부위)"},
        {c:"#94a3b8", t:"; CMT=2: Central (혈장, DV 측정) <- S2로 scaling"},
        {c:"#94a3b8", t:"; CMT=3: Peripheral (말초 분포)"},
      ]}/>
      <Warn>{"S2는 Central 구획(CMT=2)의 scaling factor다. ADVAN4에서 Central이 CMT=2이므로 S2를 사용. ADVAN3(IV 2-구획)에서는 Central이 CMT=1이므로 S1을 사용해야 한다. 이것을 헷갈리면 단위가 틀린다."}</Warn>
    </Acc>
  </div>;
}

