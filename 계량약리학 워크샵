    </Box>
  </div>;
}

// ── 9. INSIGHT ────────────────────────────────────────────
function InsightSection() {
  return <div>
    <Box title="14강 핵심 통찰 — 시뮬레이션에 대한 5가지 오해와 진실" color={C.slate}>
      {[
        {num:"01", title:"오해: 시뮬레이션은 에스티메이션 다음 단계다 → 진실: 시뮬레이션은 모델링의 목적이다", color:C.blue,
         body:"에스티메이션은 시뮬레이션을 위한 수단이다. 좋은 모델 파라미터를 추정하는 이유는 그 파라미터로 현실에서 해보지 못한 상황을 예측하기 위해서다. 이 방향을 항상 기억해야 처음부터 올바른 연구 설계(충분한 샘플링, 공변량 수집)를 할 수 있다."},
        {num:"02", title:"오해: N=1000이면 충분하다 → 진실: 목적에 따라 N이 달라진다", color:C.green,
         body:"VPC와 중위값 PTA에는 N=1000이면 충분하다. 그러나 드문 이벤트(AUC가 안전 임계값의 5% 초과 확률) 추정에는 N=10000 이상이 필요하다. 다른 시드로 결과가 크게 달라지면 N이 부족하다는 신호다."},
        {num:"03", title:"오해: 시뮬레이션은 현실을 정확히 예측한다 → 진실: 시뮬레이션은 모델 가정 안에서의 예측이다", color:C.red,
         body:"외삽 영역(임상시험 데이터 범위 밖)에서의 시뮬레이션은 '모델이 선형이다'라는 가정에 의존한다. 비선형 제거(MM 동태)나 시간 변동 PK가 있는 약물에서 선형 모델로 외삽하면 심각한 오류가 생긴다. 외삽 전 반드시 비선형성 여부를 확인해야 한다."},
        {num:"04", title:"오해: VPC가 통과하면 시뮬레이션은 믿을 수 있다 → 진실: VPC는 내부 검증이다", color:C.purple,
