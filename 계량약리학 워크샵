// ── 1. WHY ────────────────────────────────────────────────
function WhySection() {
  return <div>
    <Box title="시뮬레이션의 본질 — '해보지 않은 것'을 '해본 것'으로 만드는 기술" color={C.blue}>
      <div style={{fontSize:13, fontWeight:800, color:C.blue, textAlign:"center", padding:"10px 0", background:C.blueL, borderRadius:8, marginBottom:12}}>
        {"\"모델링은 과학이고, 시뮬레이션은 그 과학의 열매다.\""}
      </div>
      <div style={{fontSize:12.5, lineHeight:1.85, marginBottom:12}}>
        지금까지의 모든 과정 — 데이터 수집, 구조 모델 선택, 초기값 설정, NONMEM 수렴, 공변량 분석 — 은 하나의 목적을 위한 준비였다.
        그 목적이 바로 시뮬레이션이다. 좋은 모델은 <strong>우리가 실제로 해보지 않은 상황을 예측하는 능력</strong>을 갖는다.
        1mg/kg과 5mg/kg만 임상시험 했더라도, 3mg/kg, 10mg/kg, 20mg/kg에서 어떤 농도 프로파일이 나올지 예측할 수 있다.
      </div>
      <div style={{display:"flex", gap:8, marginBottom:12}}>
        <div style={{flex:1, background:C.redL, border:`1.5px solid ${C.red}33`, borderRadius:8, padding:"10px 12px"}}>
          <div style={{fontWeight:800, color:C.red, fontSize:12, marginBottom:6}}>❌ 시뮬레이션 없이</div>
          <div style={{fontSize:12, color:C.gray, lineHeight:1.7}}>
            임상시험한 용량만 안다.<br/>
            소아 환자는 성인 데이터가 없어서 추정만 한다.<br/>
            신기능 저하 환자 용량 조정 근거가 없다.<br/>
            Phase 2 용량 결정에 직감에 의존한다.
          </div>
        </div>
        <div style={{flex:1, background:C.greenL, border:`1.5px solid ${C.green}33`, borderRadius:8, padding:"10px 12px"}}>
          <div style={{fontWeight:800, color:C.green, fontSize:12, marginBottom:6}}>✅ 시뮬레이션으로</div>
          <div style={{fontSize:12, color:C.gray, lineHeight:1.7}}>
            수십 가지 용량·투여 간격을 가상으로 비교.<br/>
            공변량 모델로 소아·노인·신장애 환자 외삽.<br/>
            목표 혈중 농도 달성 확률(PTA) 계산.<br/>
            규제 제출 근거를 데이터 없이 시뮬레이션으로 생성.
          </div>
        </div>
      </div>
      <Expert>{"시뮬레이션은 '모르는 것에 대한 예측'이지 '아는 것의 확인'이 아니다. 이미 임상시험 한 용량·용법을 시뮬레이션하면 거의 관찰값과 일치한다 — 이것은 모델이 좋다는 증거가 아니라 당연한 결과다. 시뮬레이션의 진짜 가치는 '외삽(Extrapolation)', 즉 데이터 범위 밖에 있는 상황에 대한 예측이다. 따라서 '이 시뮬레이션이 외삽인가, 보간인가?'를 항상 자문해야 한다."}</Expert>
      <Warn c={C.red}>{"Garbage In, Garbage Out (GIGO): 시뮬레이션 결과의 신뢰도는 100% 입력 데이터와 모델의 품질에 달려 있다. 스파스 샘플링으로 구축한 부정확한 모델, 중요한 공변량이 빠진 모델로 시뮬레이션하면 그 결과는 오히려 잘못된 의사결정을 유도한다. 시뮬레이션 결과를 확신하기 전에 VPC로 모델의 예측력을 반드시 검증해야 한다."}</Warn>
    </Box>

    <Box title="시뮬레이션이 답할 수 있는 질문들 — R&D 단계별 정리" color={C.blue}>
      <CT headers={["R&D 단계","질문","시뮬레이션의 기여"]}
        colors={[C.blue, C.slate, C.green]}
        rows={[
          ["전임상→임상 외삽","사람에서 시작 용량은?","알로메트릭 스케일링 + PBPK로 First-in-Human 용량 예측"],
          ["Phase 1 SAD/MAD","용량 에스칼레이션 단계는? MAD PK는?","Dose escalation 시뮬레이션, Accumulation ratio 계산"],
          ["Phase 1→2 전환","Phase 2에 무슨 용량을? 몇 개 팔을?","PTA 시뮬레이션으로 용량 선택 근거. Adaptive design 정보"],
          ["특수 환자군","소아, 노인, 신장애, 간장애 환자 용량은?","공변량 모델로 외삽. 규제기관 요구 없이 용량 가이드 생성"],
          ["약물 상호작용","DDI 시 용량 조정 필요한가?","PBPK 기반 DDI 시뮬레이션 (임상 DDI 없이 라벨 클레임)"],
          ["TDM 최적화","이 환자에게 최적 용량은?","개별 PK 예측 → Target Attainment 계산 → 용량 추천"],
          ["라벨 최적화","어떤 환자군에 용량 감소 경고가 필요한가?","집단 시뮬레이션으로 안전성 임계값 추정"],
        ]}
      />
    </Box>
  </div>;
}

// ── 2. USES ───────────────────────────────────────────────
function UsesSection() {
  const [active, setActive] = useState(0);
  const categories = [
    {
      name:"용량·용법 최적화", icon:"💊", color:C.green,
      items:[
        {title:"최적 용량 탐색 (Dose Finding)", desc:"임상시험에서 1, 5mg/kg만 했더라도, 2, 3, 4, 7, 10mg/kg 등 수십 가지 용량을 가상으로 시뮬레이션. 원하는 목표 혈중 농도(Cmin, Cmax, AUC)를 달성하는 최소 유효 용량을 찾는다."},
        {title:"투여 간격 최적화 (Dosing Interval)", desc:"Q8h vs Q12h vs Q24h — 같은 일일 총 용량이라도 투여 간격에 따라 피크/트로프 농도가 달라진다. 항생제 PK/PD 지표(T>MIC, AUC/MIC, Cmax/MIC)에 맞는 최적 투여 간격 선택."},
        {title:"지속 주입 vs 단기 주입 (CI vs Intermittent)", desc:"β-lactam 항생제는 T>MIC가 핵심 PD 지표. 지속 주입(CI)이 간헐적 주입보다 T>MIC를 높이는 경우 시뮬레이션으로 증명. 같은 총 용량에서 CI가 더 효과적인지 가상 검증."},
      ]
    },
    {
      name:"특수 환자군 외삽", icon:"👥", color:C.purple,
      items:[
        {title:"소아 용량 추정 (Pediatric Extrapolation)", desc:"성인 모델 + 알로메트릭 스케일링(CL ∝ WT^0.75, V ∝ WT^1.0)으로 소아 PK 예측. 성인과 유사한 노출(AUC)을 달성하는 소아 용량 시뮬레이션. FDA는 소아 임상시험 전 이 접근을 권장."},
        {title:"노인 용량 조정 (Geriatric)", desc:"신기능 저하(eGFR 감소)를 공변량으로 반영한 시뮬레이션. '65세, eGFR 40 mL/min 환자에서 표준 용량을 주면 AUC가 몇 배 증가하는가'를 정량화."},
        {title:"신장애·간장애 환자", desc:"eGFR별(>90, 60-90, 30-60, <30) 시뮬레이션으로 용량 조정 기준 제시. 규제기관은 신장애·간장애 연구를 요구하지만, PopPK 시뮬레이션이 그 대안 근거가 될 수 있음."},
      ]
