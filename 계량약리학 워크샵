function PkSection() {
  return <div>
    <Box title="$PK 블록의 역할과 구조" color={C.blue}>
      <div style={{fontSize:12.5, lineHeight:1.8, marginBottom:8}}>
        $PK 블록은 <strong>THETA(집단 파라미터) → 개인 파라미터</strong>로 변환하는 과정을 정의한다.
        단계: ① 집단 파라미터(TVCL 등) 정의 → ② IIV(ETA) 추가 → ③ 스케일링(S) 정의
      </div>
      <Code lines={[
        {c:"#94a3b8", t:"; ── $PK 블록 완전 구조 (ADVAN4 기준) ──────────────────"},
        {c:"#fbbf24", t:"$PK"},
        {c:"#94a3b8", t:""},
        {c:"#86efac", t:"; ① 집단(Population) 파라미터 정의 [공변량 포함 권장]"},
        {c:"#e2e8f0", t:"TVCL = THETA(1) * (GFR/90)**THETA(6)   ; 신기능 보정 CL"},
        {c:"#e2e8f0", t:"TVV2 = THETA(2) * (WT/70)**1            ; 체중 보정 V"},
        {c:"#e2e8f0", t:"TVQ  = THETA(3)                         ; 구획 간 청소율"},
        {c:"#e2e8f0", t:"TVV3 = THETA(4)                         ; Peripheral V"},
        {c:"#e2e8f0", t:"TVKA = THETA(5)                         ; 흡수 속도상수"},
        {c:"#94a3b8", t:""},
        {c:"#86efac", t:"; ② 개인 파라미터 정의 [Exponential IIV = 표준]"},
        {c:"#e2e8f0", t:"CL   = TVCL * EXP(ETA(1))"},
        {c:"#e2e8f0", t:"V2   = TVV2 * EXP(ETA(2))"},
        {c:"#e2e8f0", t:"Q    = TVQ                 ; IIV 없는 경우 (불안정)"},
        {c:"#e2e8f0", t:"V3   = TVV3"},
        {c:"#e2e8f0", t:"KA   = TVKA * EXP(ETA(3))"},
        {c:"#94a3b8", t:""},
        {c:"#86efac", t:"; ③ 스케일링 파라미터 (단위 통일)"},
        {c:"#f87171", t:"S2   = V2/1000            ; AMT=mg, DV=mcg/mL → /1000"},
      ]}/>
    </Box>

    <Box title="TVCL 분리 vs 통합 — 왜 두 줄로 쓰는가?" color={C.green}>
      <div style={{display:"grid", gridTemplateColumns:"1fr 1fr", gap:8, marginBottom:10}}>
        <div>
          <div style={{fontWeight:700, color:C.grayMid, fontSize:12, marginBottom:4}}>통합 방식 (초보자 스타일)</div>
          <Code lines={[
            {c:"#e2e8f0", t:"CL = THETA(1)*EXP(ETA(1))"},
          ]}/>
          <div style={{fontSize:11.5, color:C.gray, lineHeight:1.7}}>
            간단하지만 공변량 추가 시 식이 복잡해짐.<br/>
            나중에 GFR 효과 추가하면:<br/>
            CL = THETA(1)*(GFR/90)**THETA(2)*EXP(ETA(1))
          </div>
        </div>
        <div>
          <div style={{fontWeight:700, color:C.green, fontSize:12, marginBottom:4}}>분리 방식 (권장 스타일)</div>
          <Code lines={[
            {c:"#e2e8f0", t:"TVCL = THETA(1)*(GFR/90)**THETA(2)"},
            {c:"#e2e8f0", t:"CL   = TVCL * EXP(ETA(1))"},
          ]}/>
          <div style={{fontSize:11.5, color:C.green, lineHeight:1.7}}>
            TVCL = 집단 평균 CL (공변량 반영)<br/>
            CL = 개인의 CL (IIV 반영)<br/>
            가독성 높고 공변량 탐색 용이.
          </div>
        </div>
      </div>
      <Gem>최주인 강사의 핵심 포인트: "나중에 공변량을 TVCL에 추가할 때 TVCL 줄만 수정하면 된다. 분리 방식이 수정과 검토가 훨씬 쉽다."</Gem>
    </Box>

    <Box title="Exponential IIV vs Additive IIV — 실무 선택" color={C.purple}>
      <CT
        headers={["IIV 모델","코드","특징","언제 쓰는가"]}
        colors={[C.purple, C.purple, C.purple, C.purple]}
        rows={[
          ["Exponential ★","CL = TVCL*EXP(ETA(1))","CL 항상 양수\nLog-normal 분포\nCV%=√ω²×100 (소값)","PK 파라미터 표준\n95% 이상 상황"],
          ["Additive","CL = TVCL + ETA(1)","선형 합산\nCL이 음수 가능","파라미터가 이미 log scale일 때"],
          ["Proportional","CL = TVCL*(1+ETA(1))","상대적 변이\nCV%=ω×100","드묾, Exponential 선호"],
        ]}
      />
    </Box>
  </div>;
}

