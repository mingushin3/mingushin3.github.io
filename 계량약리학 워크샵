        {c:"#86efac", t:"  Q_eff = Q * Kd / (Kd + C1)  ; 농도 의존적 Q"},
        {c:"#86efac", t:"  DADT(1) = -CL/V1*A(1) - Q_eff/V1*A(1) + Q/V2*A(2)"},
      ]}/>
