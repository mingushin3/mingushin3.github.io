function MetaModelSection() {
  return <div>
    <Box title="Parent-Metabolite 모델 — ADVAN6 활용의 핵심 사례" color={C.purple}>
      <div style={{marginBottom:10, fontSize:12.5, lineHeight:1.75}}>
        대사체 모델링은 General ADVAN이 빛나는 영역이다.
        Parent(약물 원형)와 Metabolite(대사체)가 서로 다른 구획에서 독립적으로
        생성·분포·제거되는 과정을 $DES 블록의 연립 ODE로 완벽하게 표현할 수 있다.
      </div>
      <Box title="경구 투여 + 비선형 대사체 생성 모델 구조" color={C.purple}>
        <div style={{background:"#f5f3ff", borderRadius:8, padding:"10px 12px", marginBottom:10, fontFamily:"monospace", fontSize:11.5, lineHeight:2}}>
          <div>{"CMT=1: Depot (경구 투여)"}</div>
          <div>{"  -> (KA) -> CMT=2: Parent Central"}</div>
          <div>{"              -> (CLp) 제거"}</div>
          <div>{"              -> (Vmax/Km) CMT=3: Metabolite Central (MM 비선형 생성)"}</div>
          <div>{"                              -> (CLm) 제거"}</div>
          <div>{"(Parent: 1-구획 경구, Metabolite: 1-구획, MM 생성)"}</div>
        </div>
        <Code lines={[
          {c:"#86efac", t:"$SUBROUTINE ADVAN6 TOL=6"},
          {c:"#86efac", t:"$MODEL"},
          {c:"#86efac", t:"  COMP=(DEPOT,     DEFDOSE)    ; CMT=1"},
          {c:"#86efac", t:"  COMP=(PARENT_C,  DEFOBS)     ; CMT=2: Parent 혈장"},
          {c:"#86efac", t:"  COMP=(METAB_C)               ; CMT=3: Metabolite 혈장"},
          {c:"",        t:""},
          {c:"#c4b5fd", t:"$PK"},
          {c:"#c4b5fd", t:"  KA   = THETA(1) * EXP(ETA(1))  ; 흡수 속도"},
          {c:"#c4b5fd", t:"  CLp  = THETA(2) * EXP(ETA(2))  ; Parent CL"},
          {c:"#c4b5fd", t:"  Vp   = THETA(3)                ; Parent V"},
          {c:"#c4b5fd", t:"  Vmax = THETA(4)                ; MM 최대 대사 속도"},
          {c:"#c4b5fd", t:"  Km   = THETA(5)                ; MM Michaelis 상수 (농도)"},
          {c:"#c4b5fd", t:"  CLm  = THETA(6) * EXP(ETA(3))  ; Metabolite CL"},
          {c:"#c4b5fd", t:"  Vm   = THETA(7)                ; Metabolite V"},
          {c:"#c4b5fd", t:"  MWR  = THETA(8)                ; 분자량 비율 (MW_parent/MW_metab)"},
          {c:"#c4b5fd", t:"  S2   = Vp  / 1000              ; Parent scaling"},
          {c:"#c4b5fd", t:"  S3   = Vm  / 1000              ; Metabolite scaling"},
          {c:"",        t:""},
          {c:"#fbbf24", t:"$DES"},
          {c:"#86efac", t:"  CP   = A(2) / Vp               ; Parent 농도"},
          {c:"#86efac", t:"  CM   = A(3) / Vm               ; Metabolite 농도"},
          {c:"",        t:""},
          {c:"#86efac", t:"  DADT(1) = -KA * A(1)                     ; depot"},
          {c:"#86efac", t:"  DADT(2) = KA*A(1) - CLp/Vp*A(2)"},
          {c:"#86efac", t:"            - Vmax*CP/(Km+CP)               ; MM 대사체 생성"},
          {c:"#86efac", t:"  DADT(3) = Vmax*CP/(Km+CP)*MWR - CLm/Vm*A(3)  ; 대사체"},
          {c:"#94a3b8", t:"; MWR: Parent->Metabolite 변환 시 분자량 비율 보정"},
          {c:"",        t:""},
          {c:"#f9a8d4", t:"$ERROR"},
          {c:"#f9a8d4", t:"  IF (CMT.EQ.2) Y = A(2)/S2 * (1+EPS(1)) + EPS(2) ; Parent"},
          {c:"#f9a8d4", t:"  IF (CMT.EQ.3) Y = A(3)/S3 * (1+EPS(3)) + EPS(4) ; Metabolite"},
        ]}/>
        <Gem>{"$ERROR에서 CMT로 Parent/Metabolite를 구분하는 것이 핵심 기술이다. 데이터셋에서 Parent 관측은 CMT=2, Metabolite 관측은 CMT=3으로 설정해야 한다. 각각 다른 RUV 파라미터(EPS)를 부여하는 것이 표준."}</Gem>
        <Warn>{"MWR(분자량 비율)은 Parent의 대사체 변환 시 물질 보존 법칙을 만족시키기 위해 필요하다. 예: Parent(MW=300) -> Metabolite(MW=250)이면 MWR=300/250=1.2. 이를 무시하면 대사체 농도가 systematically 편향된다."}</Warn>
      </Box>
    </Box>
  </div>;
}

