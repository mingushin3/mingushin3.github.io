        {c:"#86efac", t:"$SUBROUTINE ADVAN6 TOL=6"},
        {c:"#86efac", t:"$MODEL"},
        {c:"#86efac", t:"  COMP=(CENTRAL, DEFDOSE DEFOBS)   ; CMT=1"},
        {c:"#c4b5fd", t:"$PK"},
        {c:"#c4b5fd", t:"  Vmax = THETA(1) * EXP(ETA(1))   ; 최대 제거 속도 (mg/hr)"},
        {c:"#c4b5fd", t:"  Km   = THETA(2)                 ; MM 상수 (ng/mL = ug/L)"},
        {c:"#c4b5fd", t:"  V    = THETA(3) * EXP(ETA(2))   ; 분포 용적 (L)"},
        {c:"#c4b5fd", t:"  CL_lin = THETA(4)               ; 선형 제거 (신배설 등, L/hr)"},
        {c:"#c4b5fd", t:"  S1   = V / 1000                 ; scaling (mg -> ug)"},
        {c:"#fbbf24", t:"$DES"},
        {c:"#86efac", t:"  C = A(1) / V                    ; 현재 농도 (mg/L -> ug/L via S1)"},
        {c:"#86efac", t:"  MM_rate = Vmax * C / (Km + C)   ; MM 제거 속도"},
        {c:"#86efac", t:"  DADT(1) = -MM_rate - CL_lin/V * A(1)  ; 총 제거"},
        {c:"#94a3b8", t:"; Km은 농도 단위 (ug/L). ADVAN10의 Amount 단위와 다름!"},
      ]}/>
    </Acc>
  </div>;
}

