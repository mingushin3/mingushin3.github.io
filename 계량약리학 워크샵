// ── 8. COMPARE ────────────────────────────────────────────
function CompareSection() {
  return <div>
    <Box title="동일한 경구 2-구획 모델을 ADVAN3→ADVAN5→ADVAN6로 구현" color={C.slate}>
      <div style={{marginBottom:10}}>
        세 코드는 동일한 데이터에서 동일한 파라미터를 추정한다.
        차이는 코드 길이, 속도, 그리고 확장 가능성이다.
      </div>
    </Box>

    {[
      {title:"ADVAN4 TRANS4 (Specific — 가장 짧음)", color:C.green,
       lines:[
         {c:"#86efac", t:"$SUBROUTINE ADVAN4 TRANS4          ; 경구 2-구획 내장"},
         {c:"#c4b5fd", t:"$PK"},
         {c:"#c4b5fd", t:"  CL=THETA(1)*EXP(ETA(1))"},
         {c:"#c4b5fd", t:"  V2=THETA(2)*EXP(ETA(2))"},
         {c:"#c4b5fd", t:"  Q=THETA(3)  V3=THETA(4)  KA=THETA(5)*EXP(ETA(3))"},
         {c:"#c4b5fd", t:"  S2=V2/1000"},
         {c:"#f9a8d4", t:"$ERROR  Y=F*(1+EPS(1))+EPS(2)"},
       ],
       note:"장점: 가장 짧고 빠름. 단점: PD 확장, 비선형 흡수 추가 어려움."},
      {title:"ADVAN7 (General Linear — 구획 직접 정의)", color:C.blue,
       lines:[
         {c:"#86efac", t:"$SUBROUTINE ADVAN7                 ; General Linear (TRANS 없음)"},
         {c:"#86efac", t:"$MODEL"},
         {c:"#86efac", t:"  COMP=(DEPOT,   DEFDOSE)          ; CMT=1"},
         {c:"#86efac", t:"  COMP=(CENTRAL, DEFOBS)           ; CMT=2"},
         {c:"#86efac", t:"  COMP=(PERIPH)                   ; CMT=3"},
         {c:"#c4b5fd", t:"$PK"},
         {c:"#c4b5fd", t:"  CL=THETA(1)*EXP(ETA(1))  V2=THETA(2)*EXP(ETA(2))"},
         {c:"#c4b5fd", t:"  Q=THETA(3)  V3=THETA(4)  KA=THETA(5)*EXP(ETA(3))"},
         {c:"#c4b5fd", t:"  K20=CL/V2  K23=Q/V2  K32=Q/V3  K21=KA  S2=V2/1000"},
         {c:"#94a3b8", t:";  ^-- Rate Constants를 직접 정의해야 함 (TRANS4 없으므로)"},
         {c:"#f9a8d4", t:"$ERROR  Y=F*(1+EPS(1))+EPS(2)"},
       ],
       note:"장점: 구획 확장 가능. 단점: Rate Constant 수동 정의 필요. $DES 없으므로 비선형 불가."},
      {title:"ADVAN6 TOL=6 (General Nonlinear — 최대 자유도)", color:C.red,
       lines:[
         {c:"#86efac", t:"$SUBROUTINE ADVAN6 TOL=6           ; General Nonlinear (★TOL 필수)"},
         {c:"#86efac", t:"$MODEL"},
         {c:"#86efac", t:"  COMP=(DEPOT,   DEFDOSE)          ; CMT=1"},
         {c:"#86efac", t:"  COMP=(CENTRAL, DEFOBS)           ; CMT=2"},
         {c:"#86efac", t:"  COMP=(PERIPH)                   ; CMT=3"},
         {c:"#c4b5fd", t:"$PK"},
         {c:"#c4b5fd", t:"  CL=THETA(1)*EXP(ETA(1))  V2=THETA(2)*EXP(ETA(2))"},
         {c:"#c4b5fd", t:"  Q=THETA(3)  V3=THETA(4)  KA=THETA(5)*EXP(ETA(3))  S2=V2/1000"},
         {c:"#fbbf24", t:"$DES                               ; ★미분방정식 직접 정의"},
         {c:"#86efac", t:"  DADT(1) = -KA * A(1)"},
         {c:"#86efac", t:"  DADT(2) = KA*A(1) - (CL+Q)/V2*A(2) + Q/V3*A(3)"},
         {c:"#86efac", t:"  DADT(3) = Q/V2*A(2) - Q/V3*A(3)"},
         {c:"#f9a8d4", t:"$ERROR  Y=F*(1+EPS(1))+EPS(2)"},
       ],
       note:"장점: 나중에 비선형 흡수, Transit, PD 구획 추가 용이. 단점: 코드 길고 약간 느림."},
    ].map((m,i)=>(
      <div key={i} style={{background:m.color+"06", border:`1.5px solid ${m.color}33`, borderRadius:10, padding:"12px 14px", marginBottom:10}}>
        <div style={{fontWeight:800, fontSize:12.5, color:m.color, marginBottom:8}}>{m.title}</div>
        <Code lines={m.lines}/>
        <div style={{fontSize:11.5, color:C.gray, lineHeight:1.6}}>{m.note}</div>
      </div>
