function GeneralSection() {
  return <div>
    <Box title="General ADVAN 분류 체계" color={C.blue}>
      <CT headers={["분류", "ADVAN", "특징", "$DES 필요?", "사용 상황"]}
        colors={[C.blue, C.blue, C.blue, C.blue, C.blue]}
        rows={[
          ["General Linear",   "ADVAN5, ADVAN7", "선형 모델. 내장 ODE solver.", "불필요", "복잡한 선형 PK. 다구획 선형."],
          ["General Nonlinear","ADVAN6, ADVAN8", "비선형 ODE. 일반 step 방법.", "★필수", "비선형 흡수, Transit, TMDD"],
          ["General Nonlinear","ADVAN9",         "비선형 + lag time.",           "★필수", "흡수 지연이 있는 비선형"],
          ["General Nonlinear","ADVAN13 ★",      "Stiff ODE solver. 가장 강력.","★필수", "TMDD, 복잡 PK/PD. 만능 열쇠"],
        ]}
      />
      <Gem>{"ADVAN13이 실무 만능 열쇠인 이유: Stiff ODE solver를 사용해 매우 빠른 속도 변화(예: TMDD에서 target saturation)도 안정적으로 계산한다. ADVAN6가 불안정하면 ADVAN13으로 교체."}</Gem>
    </Box>

    <Box title="General ADVAN 사용 시 필수 추가 블록: $MODEL" color={C.blue}>
      <Code lines={[
        {c:"#94a3b8", t:"; General ADVAN에서 $MODEL로 구획 정의 (Specific ADVAN은 불필요)"},
        {c:"#86efac", t:"$SUBROUTINE ADVAN6 TOL=6"},
        {c:"",        t:""},
        {c:"#86efac", t:"$MODEL"},
        {c:"#86efac", t:"  COMP=(DEPOT,    DEFDOSE)    ; CMT=1: 투여 구획 (기본 투여)"},
        {c:"#86efac", t:"  COMP=(CENTRAL,  DEFOBS)     ; CMT=2: 중심 구획 (기본 관측)"},
        {c:"#86efac", t:"  COMP=(PERIPH)               ; CMT=3: 말초 구획"},
        {c:"",        t:""},
        {c:"#94a3b8", t:"; DEFDOSE: 이 구획에 AMT가 기본 투여됨"},
        {c:"#94a3b8", t:"; DEFOBS:  이 구획에서 DV가 기본 관측됨"},
        {c:"#94a3b8", t:"; 구획 이름은 자유롭게 지정 (이 이름은 $DES에서 참조 가능)"},
      ]}/>
    </Box>

    <Acc title="$DES 블록 — ODE를 직접 코딩하는 방법" color={C.red}>
      <Box title="$DES 문법 핵심 규칙" color={C.red}>
        <CT headers={["변수", "의미", "단위", "예시"]}
          colors={[C.red, C.red, C.red, C.red]}
          rows={[
            ["A(n)",   "n번 구획의 현재 약물 양(Amount)", "투여 단위와 동일", "A(1)=depot 약물 양"],
            ["DADT(n)","A(n)의 시간에 따른 변화율",       "양/시간",          "DADT(1) = -KA*A(1)"],
            ["T",      "현재 시간 (모델 내에서 참조 가능)","TIME 단위",        "CIRCADIAN 리듬 등"],
            ["F",      "예측 농도값 ($ERROR에서)",        "농도 단위",         "$ERROR: Y=F+EPS"],
          ]}
        />
        <Code lines={[
          {c:"#94a3b8", t:"; $DES 작성 원칙: 각 구획의 약물 유입/유출을 미분방정식으로 기술"},
          {c:"#fbbf24", t:"$DES"},
          {c:"#94a3b8", t:"; 경구 2-구획 ODE (First-order kinetics)"},
          {c:"#86efac", t:"  DADT(1) = -KA * A(1)                              ; depot 유출"},
          {c:"#86efac", t:"  DADT(2) = KA*A(1) - CL/V2*A(2) - Q/V2*A(2) + Q/V3*A(3)  ; central"},
          {c:"#86efac", t:"  DADT(3) = Q/V2*A(2) - Q/V3*A(3)                  ; peripheral"},
          {c:"",        t:""},
          {c:"#94a3b8", t:"; DADT = d(Amount)/dt = (유입 속도) - (유출 속도)"},
          {c:"#94a3b8", t:"; 부호 규칙: 들어오면 +, 나가면 -"},
        ]}/>
      </Box>
      <Box title="TOL 파라미터 — ADVAN6/9/13 필수" color={C.amber}>
        <div style={{fontSize:12.5, lineHeight:1.75, marginBottom:8}}>
          General Nonlinear ADVAN에서 <code style={{background:"#f1f5f9", padding:"1px 4px", borderRadius:3}}>TOL=</code>은 ODE 수치 적분의 허용 오차(tolerance)를 지정한다.
        </div>
        <CT headers={["TOL 값", "정밀도", "계산 속도", "권장 상황"]}
          colors={[C.amber, C.amber, C.amber, C.amber]}
          rows={[
            ["TOL=3", "낮음",   "빠름",    "탐색적 모델링 (초기 단계)"],
            ["TOL=4", "중간",   "중간",    "일반 목적"],
            ["TOL=6 ★","높음",  "느림",    "최종 모델, 규제 제출"],
            ["TOL=9", "매우 높음","매우 느림","수치 불안정 디버깅 시"],
          ]}
        />
        <Warn>{"TOL 생략 시 ADVAN6/9/13은 에러가 나거나 부정확한 결과를 낸다. 반드시 $SUBROUTINE 라인에 TOL=6을 기본으로 지정하라."}</Warn>
      </Box>
    </Acc>

    <Acc title="ADVAN6 비선형 흡수 모델 예시 — Transit Compartment (Savic 2007)" color={C.purple}>
      <Code lines={[
        {c:"#94a3b8", t:"; Transit Compartment 흡수 모델 (경구 MR 제형 등)"},
        {c:"#86efac", t:"$SUBROUTINE ADVAN6 TOL=6"},
        {c:"",        t:""},
        {c:"#86efac", t:"$MODEL"},
        {c:"#86efac", t:"  COMP=(TRANSIT1, DEFDOSE) ; CMT=1: 1번 Transit"},
        {c:"#86efac", t:"  COMP=(TRANSIT2)           ; CMT=2"},
        {c:"#86efac", t:"  COMP=(TRANSIT3)           ; CMT=3"},
        {c:"#86efac", t:"  COMP=(CENTRAL,  DEFOBS)   ; CMT=4: 중심 (혈장)"},
        {c:"",        t:""},
        {c:"#c4b5fd", t:"$PK"},
        {c:"#c4b5fd", t:"  KTR = (NN+1) / MTT        ; transit rate constant"},
        {c:"#c4b5fd", t:"  CL  = THETA(1) * EXP(ETA(1))"},
        {c:"#c4b5fd", t:"  V   = THETA(2) * EXP(ETA(2))"},
        {c:"#c4b5fd", t:"  MTT = THETA(3) * EXP(ETA(3)) ; Mean Transit Time"},
        {c:"#c4b5fd", t:"  NN  = THETA(4)              ; Number of Transit comps"},
        {c:"#c4b5fd", t:"  S4  = V / 1000"},
        {c:"",        t:""},
        {c:"#fbbf24", t:"$DES"},
        {c:"#86efac", t:"  DADT(1) = -KTR * A(1)              ; depot->T1"},
        {c:"#86efac", t:"  DADT(2) = KTR*A(1) - KTR*A(2)      ; T1->T2"},
        {c:"#86efac", t:"  DADT(3) = KTR*A(2) - KTR*A(3)      ; T2->T3"},
        {c:"#86efac", t:"  DADT(4) = KTR*A(3) - CL/V*A(4)     ; T3->Central"},
      ]}/>
      <Gem>{"Transit Compartment 모델(Savic 2007)은 서방정, 식후 복용 등 복잡한 흡수를 표현하는 표준 방법이다. MTT(평균 통과 시간)와 NN(Transit 구획 수)으로 흡수 속도와 모양을 동시에 제어할 수 있다."}</Gem>
    </Acc>
  </div>;
}

