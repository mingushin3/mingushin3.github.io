  <script type="text/babel" data-presets="react,typescript">
/* ========== Lecture 01: 계량약리학 입문 ========== */
const Lecture01 = (() => {
  const { useState, useEffect, useRef, useMemo, useCallback, useReducer } = React;
const C = {
  blue:"#1e40af", blueL:"#dbeafe", blueMid:"#3b82f6",
  red:"#b91c1c", redL:"#fee2e2",
  green:"#166534", greenL:"#dcfce7", greenMid:"#16a34a",
  purple:"#6d28d9", purpleL:"#ede9fe",
  amber:"#92400e", amberL:"#fef3c7",
  gray:"#374151", grayL:"#f9fafb", grayMid:"#6b7280",
  teal:"#0f766e", tealL:"#ccfbf1",
  slate:"#1e293b", orange:"#c2410c", orangeL:"#ffedd5",
};

const sections = [
  {id:"why",      label:"① 계량약리학이란",        icon:"🎓"},
  {id:"dose",     label:"② Dose→Exposure→Response",icon:"📈"},
  {id:"model",    label:"③ 모델의 본질",            icon:"🧮"},
  {id:"nca",      label:"④ NCA vs 모델링",          icon:"⚖"},
  {id:"mixed",    label:"⑤ 혼합효과모델",           icon:"🔀"},
  {id:"pop",      label:"⑥ Population vs 개인",     icon:"👥"},
  {id:"midd",     label:"⑦ MIDD — 신약 개발의 패러다임", icon:"🚀"},
  {id:"question", label:"⑧ 핵심 질문 프레임워크",   icon:"❓"},
  {id:"insight",  label:"⑨ 거장의 통찰",            icon:"💡"},
];

const Box = ({title, color=C.blue, bg, children}) => (
  <div style={{background:bg||color+"0d", border:`1.5px solid ${color}33`, borderRadius:10, padding:"12px 14px", marginBottom:12}}>
    {title && <div style={{display:"flex", alignItems:"center", gap:8, marginBottom:8}}>
      <div style={{width:3, height:18, background:color, borderRadius:2}}/>
      <span style={{fontWeight:800, fontSize:13, color}}>{title}</span>
    </div>}
    <div style={{fontSize:12.5, lineHeight:1.75, color:C.slate}}>{children}</div>
  </div>
);
const Warn = ({c=C.amber, children}) => (
  <div style={{background:c+"15", border:`1px solid ${c}88`, borderRadius:8, padding:"8px 12px", fontSize:12, color:c, marginBottom:10, lineHeight:1.7}}>{"⚠️ "}{children}</div>
);
const Gem = ({children}) => (
  <div style={{background:C.tealL, border:`1px solid #5eead4`, borderRadius:8, padding:"8px 12px", fontSize:12, color:C.teal, marginBottom:10, lineHeight:1.7, fontWeight:600}}>{"💎 "}{children}</div>
);
const Expert = ({children}) => (
  <div style={{background:C.purpleL, border:`1px solid #c4b5fd`, borderRadius:8, padding:"8px 12px", fontSize:12, color:C.purple, marginBottom:10, lineHeight:1.7, fontWeight:600}}>{"🔬 거장의 시각: "}{children}</div>
);
const Clin = ({children}) => (
  <div style={{background:C.orangeL, border:`1px solid #fdba74`, borderRadius:8, padding:"8px 12px", fontSize:12, color:C.orange, marginBottom:10, lineHeight:1.7, fontWeight:600}}>{"🏥 임상 실무: "}{children}</div>
