        {c:"#86efac", t:"  COMP=(PERIPH)               ; CMT=4: 말초 분포"},
        {c:"#86efac", t:"  COMP=(BRAIN)                ; CMT=5: 뇌 구획 (BBB 통과)"},
        {c:"",        t:""},
        {c:"#c4b5fd", t:"$PK"},
        {c:"#c4b5fd", t:"  ; 흡수 파라미터"},
        {c:"#c4b5fd", t:"  F1   = THETA(1)            ; Depot1 BA"},
        {c:"#c4b5fd", t:"  F2   = 1 - F1              ; Depot2 BA (보완)"},
        {c:"#c4b5fd", t:"  KA1  = THETA(2) * EXP(ETA(1))"},
        {c:"#c4b5fd", t:"  KA2  = THETA(3)            ; 두번째 (더 느린) 흡수"},
        {c:"#c4b5fd", t:"  ALAG1 = THETA(4)           ; 흡수 지연"},
        {c:"#c4b5fd", t:"  D2   = THETA(5)            ; Depot2 주입 기간 (Zero-order)"},
        {c:"#c4b5fd", t:"  ; PK 파라미터"},
        {c:"#c4b5fd", t:"  CL   = THETA(6) * EXP(ETA(2))"},
        {c:"#c4b5fd", t:"  V3   = THETA(7) * EXP(ETA(3))  ; Plasma V"},
        {c:"#c4b5fd", t:"  Q    = THETA(8)  V4 = THETA(9) ; 말초 분포"},
        {c:"#c4b5fd", t:"  CLbr = THETA(10) Vbr = THETA(11) ; 뇌 구획"},
        {c:"#c4b5fd", t:"  S3   = V3 / 1000            ; scaling"},
        {c:"#fbbf24", t:"$DES"},
        {c:"#86efac", t:"  DADT(1) = -KA1 * A(1)                        ; Depot1"},
        {c:"#86efac", t:"  DADT(2) = -A(2)/D2                           ; Depot2 (zero-order)"},
        {c:"#86efac", t:"  DADT(3) = KA1*A(1) + A(2)/D2 - (CL+Q)/V3*A(3) + Q/V4*A(4) - CLbr/V3*A(3)"},
        {c:"#86efac", t:"  DADT(4) = Q/V3*A(3) - Q/V4*A(4)             ; Peripheral"},
        {c:"#86efac", t:"  DADT(5) = CLbr/V3*A(3) - CLbr/Vbr*A(5)     ; Brain"},
      ]}/>
    </Acc>
  </div>;
}

