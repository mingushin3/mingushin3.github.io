    </Box>

    <Acc title="$PRED 사용 예 1 — QT 연장 PD 모델 (C-QTc 관계)" color={C.amber}>
      <Code lines={[
        {c:"#94a3b8", t:"; $PRED: 농도-QTc 관계 PD 모델"},
        {c:"#94a3b8", t:"; (PK는 별도 실행 후 IPRED를 공변량으로 입력)"},
        {c:"#fbbf24", t:"$PRED"},
        {c:"#86efac", t:"  EMAX  = THETA(1)             ; 최대 QTc 연장"},
        {c:"#86efac", t:"  EC50  = THETA(2)             ; EC50 (ng/mL)"},
        {c:"#86efac", t:"  SLOPE = THETA(3)             ; linear slope"},
        {c:"#86efac", t:"  BASE  = THETA(4) * EXP(ETA(1)) ; 기저 QTc (IIV)"},
        {c:"",        t:""},
        {c:"#86efac", t:"  ; E-max model"},
        {c:"#86efac", t:"  EMODEL = EMAX * C / (EC50 + C)"},
        {c:"",        t:""},
        {c:"#86efac", t:"  IPRED = BASE + EMODEL        ; 개인별 예측값"},
        {c:"#86efac", t:"  Y     = IPRED + EPS(1)       ; Additive RUV"},
      ]}/>
    </Acc>

    <Acc title="$PRED 사용 예 2 — 이진 반응 (Binary Response: 부작용 발생 여부)" color={C.amber}>
      <Code lines={[
        {c:"#94a3b8", t:"; $PRED: Binary Response (0=없음, 1=발생)"},
        {c:"#94a3b8", t:"; Logistic regression + ETA"},
        {c:"#fbbf24", t:"$PRED"},
        {c:"#86efac", t:"  BASEP = THETA(1)             ; baseline log-odds"},
        {c:"#86efac", t:"  SLOPE = THETA(2)             ; drug effect slope"},
        {c:"#86efac", t:"  ETA1  = ETA(1)               ; inter-individual var"},
        {c:"",        t:""},
        {c:"#86efac", t:"  ; 로지스틱 함수"},
        {c:"#86efac", t:"  LOGIT = BASEP + SLOPE*C + ETA1"},
        {c:"#86efac", t:"  P1    = EXP(LOGIT) / (1 + EXP(LOGIT))  ; P(event=1)"},
        {c:"",        t:""},
        {c:"#86efac", t:"  ; Bernoulli likelihood"},
        {c:"#86efac", t:"  IF (DV.EQ.1) Y = P1"},
        {c:"#86efac", t:"  IF (DV.EQ.0) Y = 1 - P1"},
      ]}/>
      <Gem>{"이진 반응 모델은 $PRED와 $EST METHOD=LAPLACE 또는 METHOD=COND LAPLACIAN 조합이 필요하다. FOCE-I는 연속형 데이터에 최적화됐고, 이진 데이터에는 Laplace 근사법이 더 정확하다."}</Gem>
    </Acc>

    <Acc title="$PRED 사용 예 3 — 순환 리듬이 있는 호르몬 PD 모델" color={C.amber}>
      <Code lines={[
        {c:"#94a3b8", t:"; $PRED: Circadian Rhythm 포함 Cortisol 모델"},
        {c:"#fbbf24", t:"$PRED"},
        {c:"#86efac", t:"  MESOR = THETA(1) * EXP(ETA(1)) ; 기준값 (평균)"},
        {c:"#86efac", t:"  AMP   = THETA(2)               ; 리듬 진폭"},
        {c:"#86efac", t:"  ACRO  = THETA(3)               ; 최고점 시각 (hr)"},
        {c:"",        t:""},
        {c:"#86efac", t:"  ; 코사인 기반 24시간 순환 리듬"},
        {c:"#86efac", t:"  PI    = 3.14159"},
        {c:"#86efac", t:"  CIRC  = AMP * COS(2*PI*(T - ACRO)/24)"},
        {c:"",        t:""},
        {c:"#86efac", t:"  DRUG_EFF = -THETA(4) * C       ; 약물 억제 효과"},
        {c:"#86efac", t:"  IPRED = MESOR + CIRC + DRUG_EFF"},
        {c:"#86efac", t:"  Y     = IPRED * (1 + EPS(1)) + EPS(2)"},
      ]}/>
    </Acc>
  </div>;
}

