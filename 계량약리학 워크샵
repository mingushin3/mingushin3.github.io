          {c:"#86efac", t:"  ; T를 사용 (올바름: $DES 안에서 연속 시간 변수)"},
          {c:"#86efac", t:"  KA_T = KA0 * EXP(-KDEG * T)       ; 시간에 따른 KA 변화"},
          {c:"#86efac", t:"  DADT(1) = -KA_T * A(1)"},
          {c:"",        t:""},
          {c:"#fca5a5", t:"  ; TIME을 사용 (잘못됨: $DES에서 TIME은 상수로 인식됨)"},
          {c:"#fca5a5", t:"  ; KA_T = KA0 * EXP(-KDEG * TIME)  <- 이렇게 쓰지 말 것"},
