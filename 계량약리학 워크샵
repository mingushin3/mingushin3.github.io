        <Warn>{"$DES 블록에서 시간을 참조할 때는 반드시 대문자 T를 사용해야 한다. TIME은 $PK에서 고정된 상수로 인식되어 미분 과정에서 변화하지 않는다."}</Warn>
      </Box>
    </Acc>
  </div>;
}

// ── 6. TOL ────────────────────────────────────────────────
function TolSection() {
  return <div>
    <Box title="TOL — Nonlinear ADVAN에서 정밀도를 제어하는 파라미터" color={C.teal}>
      <div style={{marginBottom:10}}>
        <strong>TOL(Tolerance)</strong>은 ODE 수치 적분 시 각 구획의 약물량(Amount)을 얼마나 정확하게 계산할 것인가를
        지정하는 파라미터다. 유효 숫자(Significant Digits)의 수로 이해하면 된다.
      </div>
      <div style={{background:C.tealL, borderRadius:8, padding:"10px 12px", marginBottom:10, fontFamily:"monospace", fontSize:12.5, lineHeight:2.2}}>
        <div>{"$SUBROUTINE ADVAN6 TOL=6"}</div>
        <div style={{color:C.grayMid, fontSize:11}}>{"TOL=6: 각 구획의 약물량을 소수점 6자리까지 정확히 계산"}</div>
      </div>
      <CT headers={["TOL 값", "계산 정밀도", "속도", "권장 상황"]}
        colors={[C.teal, C.teal, C.teal, C.teal]}
        rows={[
          ["TOL=3", "낮음 (3 significant digits)", "빠름",    "초기 탐색. 빠른 확인용"],
          ["TOL=4", "중간 (4 significant digits)", "중간",    "일반 탐색 모델링"],
          ["TOL=5", "중상 (5 significant digits)", "약간 느림","중간 단계"],
          ["TOL=6 ★","높음 (6 significant digits)", "느림",   "★최종 모델. 규제 제출 표준"],
          ["TOL=9", "매우 높음",                    "매우 느림","수치 불안정 디버깅"],
        ]}
      />
    </Box>

    <Box title="TOL과 SIGDIG의 관계 — 왜 TOL이 SIGDIG보다 커야 하는가?" color={C.teal}>
      <div style={{background:C.blueL, borderRadius:8, padding:"10px 12px", marginBottom:10, fontSize:12.5, lineHeight:1.8}}>
        <strong>$ESTIMATION METHOD=COND INTER SIGDIG=3</strong> (기본값)이라면<br/>
        파라미터 추정의 유효 숫자 = 3자리<br/>
        <br/>
        파라미터를 정확히 추정하려면 그 계산 재료인 Amount의 정밀도가 더 높아야 한다<br/>
        따라서 <strong>TOL = SIGDIG + 1~2</strong> 를 권장한다<br/>
        SIGDIG=3 → TOL=4 또는 5<br/>
        SIGDIG=3 + 안전 마진 → TOL=6 (최종 모델 표준)
      </div>
      <Warn>{"TOL 생략 시 ADVAN6/8/9/13은 실행되지 않거나 경고 없이 부정확한 결과를 낼 수 있다. $SUBROUTINE ADVAN6라고만 쓰면 에러가 발생한다. 반드시 TOL=을 명시해야 한다."}</Warn>
      <Gem>{"실무 표준: 탐색 단계에서는 TOL=4로 빠르게, 최종 모델 확정 후 규제 제출용에서는 TOL=6으로 재실행. 두 결과를 비교해서 파라미터 값이 크게 다르면 TOL을 높여야 한다는 신호다."}</Gem>
    </Box>
  </div>;
}

