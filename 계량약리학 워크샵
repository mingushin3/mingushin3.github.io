// ── 2. LSQ ────────────────────────────────────────────────
function LsqSection() {
  return <div>
    <Box title="잔차(Residual)의 정의 — 모든 것의 출발점" color={C.blue}>
      <div style={{background:C.blueL, borderRadius:8, padding:"10px 12px", marginBottom:10, fontFamily:"monospace", fontSize:13, lineHeight:2.2, textAlign:"center"}}>
        <div>{"잔차 (Residual) = 관측값 (y_obs) - 예측값 (y_pred)"}</div>
        <div style={{color:C.grayMid, fontSize:11}}>{"모델이 완벽하다면 잔차=0. 실제로는 항상 잔차가 존재한다."}</div>
      </div>
      <div>모든 최소제곱법은 <strong>잔차를 가능한 한 작게 만드는 파라미터</strong>를 찾는 방법이다. 방법론이 OLS → WLS → ELS로 발전한 것은 "어떤 잔차를 어떻게 최소화할 것인가"에 대한 해답이 정교해진 역사다.</div>
    </Box>

    <div style={{display:"flex", flexDirection:"column", gap:8}}>
      {[
        {name:"OLS (Ordinary Least Squares)", abbr:"OLS", color:C.green,
         formula:"minimize Σ(y_obs - y_pred)²",
         idea:"모든 잔차에 동일한 가중치. 가장 단순.",
         problem:"고농도 잔차(10)가 저농도 잔차(0.01)보다 수천 배 커서 고농도 위주로 피팅됨.",
         use:"선형 회귀, Dose-proportionality 검정(AUC∝Dose)"},
        {name:"WLS (Weighted Least Squares)", abbr:"WLS", color:C.blue,
         formula:"minimize Σ W_i × (y_obs - y_pred)²   [W_i = 1/Var(y_i)]",
         idea:"분산이 작은 데이터(저농도, 정확한 측정)에 더 높은 가중치.",
         problem:"분산을 키우면 OFV가 내려가는 허점 → 분산 부풀리기로 OFV 조작 가능.",
         use:"잘 사용 안 함 (ELS가 이를 해결)"},
        {name:"ELS (Extended Least Squares) ★", abbr:"ELS", color:C.red,
         formula:"minimize Σ [(y_obs-y_pred)²/σ² + ln(σ²)]",
         idea:"잔차 제곱/σ² 항(분산과 반비례) + ln(σ²) 항(분산과 비례). 두 항이 상충하여 분산 부풀리기 불가.",
         problem:"계산 복잡. 하지만 Maximum Likelihood와 수학적으로 동일하여 통계적으로 최적.",
         use:"★NONMEM 표준 방법"},
      ].map((m,i)=>(
        <div key={i} style={{background:m.color+"07", border:`1.5px solid ${m.color}33`, borderRadius:10, padding:"10px 14px"}}>
          <div style={{display:"flex", alignItems:"center", gap:8, marginBottom:6}}>
            <span style={{background:m.color, color:"#fff", fontWeight:800, fontSize:11, padding:"2px 8px", borderRadius:4}}>{m.abbr}</span>
            <span style={{fontWeight:800, fontSize:13, color:m.color}}>{m.name}</span>
          </div>
          <div style={{fontFamily:"monospace", fontSize:12, background:"#f8fafc", padding:"6px 10px", borderRadius:6, marginBottom:8, color:C.slate}}>{m.formula}</div>
          <div style={{display:"flex", gap:8, flexWrap:"wrap", fontSize:11.5}}>
            <div style={{flex:1}}><span style={{fontWeight:700, color:C.green}}>아이디어: </span>{m.idea}</div>
            <div style={{flex:1}}><span style={{fontWeight:700, color:C.red}}>한계/문제: </span>{m.problem}</div>
            <div style={{flex:1}}><span style={{fontWeight:700, color:C.teal}}>사용 상황: </span>{m.use}</div>
          </div>
        </div>
      ))}
    </div>

    <Box title="ELS가 WLS의 분산 부풀리기를 막는 원리 — 두 항의 상충" color={C.red}>
      <div style={{display:"flex", gap:10, flexWrap:"wrap"}}>
        {[
          {term:"(y-ŷ)²/σ²  항", behavior:"σ²가 커질수록 → 이 항은 작아짐 (분모가 커지니까)", effect:"OFV 감소 방향 (σ² ↑ 선호)", color:C.green},
          {term:"ln(σ²)  항", behavior:"σ²가 커질수록 → 이 항은 커짐 (로그도 증가하니까)", effect:"OFV 증가 방향 (σ² ↑ 반대)", color:C.red},
        ].map((t,i)=>(
          <div key={i} style={{flex:"1 1 220px", background:t.color+"08", border:`1px solid ${t.color}33`, borderRadius:8, padding:"8px 10px"}}>
            <div style={{fontFamily:"monospace", fontWeight:700, fontSize:12.5, color:t.color}}>{t.term}</div>
            <div style={{fontSize:11.5, color:C.gray, marginTop:4, lineHeight:1.6}}>{t.behavior}</div>
            <div style={{fontSize:11, color:t.color, fontWeight:600, marginTop:4}}>{t.effect}</div>
          </div>
        ))}
      </div>
      <div style={{marginTop:10, fontSize:12.5, lineHeight:1.75}}>두 항이 서로 반대 방향으로 작용하므로, OFV를 최소화하는 σ²의 최적값이 자연스럽게 찾아진다. 분산을 부풀려 한 항을 줄여도 다른 항이 커져 OFV가 내려가지 않는다.</div>
    </Box>
  </div>;
}

// ── 3. LIKELIHOOD ─────────────────────────────────────────
function LikelihoodSection() {
  return <div>
    <Box title="Probability vs Likelihood — 방향이 반대인 두 개념" color={C.purple}>
      <CT headers={["개념","알고 있는 것","구하는 것","예시"]}
        colors={[C.slate, C.purple, C.purple, C.purple]}
        rows={[
          ["Probability\n(확률)", "파라미터 θ (예: 동전 앞면 확률 = 0.5)", "관측값의 확률\nP(X|θ)", "앞면 0.5인 동전을 10번 던지면 앞면이 5번 나올 확률은?"],
          ["Likelihood\n(우도) ★", "관측값 X (예: 앞면 7번 나옴)", "파라미터의 우도\nL(θ|X)", "동전을 10번 던져 앞면이 7번 나왔다. 이 동전의 앞면 확률(θ)은 얼마인가?"],
        ]}
      />
      <Gem>{"PK 모델링에서: 관측값(농도 데이터)이 이미 있다 → Likelihood! 이 데이터가 나타날 가능성을 최대화하는 CL, V 값을 찾는 것 = Maximum Likelihood Estimation (MLE) = NONMEM이 하는 일."}</Gem>
    </Box>

    <Box title="Likelihood의 핵심 성질 — 직관적 이해" color={C.purple}>
      <div style={{display:"flex", gap:10, flexWrap:"wrap", marginBottom:10}}>
        {[
          {title:"확률(P)과의 차이",
           body:"확률 밀도함수(PDF)는 x에 대한 함수 → 적분하면 1. Likelihood는 θ에 대한 함수 → 적분해도 1이 아님. Likelihood는 '얼마나 그럴듯한가'의 상대적 척도.",
           color:C.purple},
          {title:"MLE의 원리",
           body:"L(θ|X)를 최대화하는 θ 찾기. 정규분포 가정 시 L이 최대인 θ = 관측값의 평균. 예: x = 1,3,4,6,8,9,0에서 L 최대 μ = 5.5",
           color:C.blue},
          {title:"왜 ln L을 쓰는가",
           body:"L = 각 관측치 확률의 곱 → 매우 작은 수. ln을 취하면 곱셈 → 덧셈으로 변환. 계산이 수치적으로 안정적. ln L 최대 = L 최대 (ln은 단조 증가 함수)",
           color:C.green},
        ].map((c,i)=>(
          <div key={i} style={{flex:"1 1 200px", background:c.color+"08", border:`1px solid ${c.color}33`, borderRadius:8, padding:"8px 10px"}}>
            <div style={{fontWeight:700, color:c.color, fontSize:12, marginBottom:5}}>{c.title}</div>
            <div style={{fontSize:11.5, color:C.gray, lineHeight:1.6}}>{c.body}</div>
          </div>
        ))}
      </div>
    </Box>

    <Box title="OFV = -2 ln L 유도 — 왜 음수 2배인가?" color={C.green}>
      <div style={{background:C.greenL, borderRadius:8, padding:"10px 14px", marginBottom:10, fontFamily:"monospace", fontSize:12, lineHeight:2.2}}>
        <div>{"정규분포 가정: ln L = -N/2 × ln(2π) - Σ[ln(σᵢ²)/2 + (yᵢ-ŷᵢ)²/(2σᵢ²)]"}</div>
        <div>{"양변에 -2 곱: -2 ln L = N×ln(2π) + Σ[ln(σᵢ²) + (yᵢ-ŷᵢ)²/σᵢ²]"}</div>
        <div>{"                       ↑상수 (최소화에 무관)    ↑OFV 항 (ELS와 동일!)"}</div>
      </div>
      <CT headers={["이유","설명"]}
        colors={[C.green, C.green]}
        rows={[
          ["-2를 곱하는 이유","카이제곱 분포로의 변환. ΔOFV가 자유도 k인 카이제곱 분포를 따름 → LRT 가능"],
          ["최소화 vs 최대화","Likelihood는 최대화, OFV는 최소화 → 방향만 반대, 수학적으로 동일"],
          ["상수항 무시","N×ln(2π)는 데이터가 같으면 항상 동일 → 모델 비교에 영향 없음"],
        ]}
      />
      <Gem>{"NONMEM이 출력하는 OFV = -2 ln L. 이것을 줄이는 것 = Likelihood를 키우는 것 = 데이터를 더 잘 설명하는 파라미터를 찾는 것. 이 세 가지가 모두 동일하다."}</Gem>
    </Box>
  </div>;
}

// ── 4. OFV & LRT ──────────────────────────────────────────
