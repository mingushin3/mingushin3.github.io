// ── 7. GOF PLOTS ─────────────────────────────────────────
function GofSection() {
  const [active, setActive] = useState(0);
  const plots = [
    {
      name:"① PRED vs DV", subtitle:"모집단 예측 vs 관찰값",
      color:C.blue,
      what:"X축: PRED (Population Prediction, η=0인 전형적 환자 예측), Y축: DV (실제 관찰 농도). 두 개가 일치하면 모집단 수준에서 모델이 잘 설명한다는 의미.",
      ideal:"빨간 추세선(LOESS)이 검정 대각선(Line of Identity, LOI)에 밀착되어 있어야 함. LOI: y=x 직선.",
      bad:[
        "추세선이 LOI 아래로 처짐 → 모델이 관찰보다 크게 예측(과예측, Over-prediction)",
        "추세선이 LOI 위로 올라감 → 과소예측(Under-prediction)",
        "높은 농도에서만 이탈 → 비선형 제거(MM kinetics) 가능성",
        "x축과 y축 스케일이 다르면 이탈 여부를 가릴 수 있음 — 동일 스케일로 그려야 함",
      ],
      expert:"PRED vs DV만으로는 BSV(Between-Subject Variability)가 반영되지 않았으므로 일반적으로 IPRED vs DV보다 점들이 더 퍼져 있다. 이것은 정상이다. 핵심은 추세선의 기울기와 절편이다.",
    },
    {
      name:"② IPRED vs DV", subtitle:"개별 예측 vs 관찰값",
      color:C.green,
      what:"X축: IPRED (Individual Prediction, 개인별 η가 반영된 예측), Y축: DV. PRED vs DV보다 점들이 LOI에 훨씬 밀착되어야 한다 — BSV가 이미 반영됐기 때문.",
      ideal:"점들이 LOI 주변에 무작위로 분포. 추세선이 LOI에 거의 겹침. η수축이 낮을 때만 신뢰 가능.",
      bad:[
        "IPRED vs DV가 PRED vs DV보다 나아지지 않음 → 개별 피팅 실패 → η 추정이 안 됨 → 데이터 희소 또는 η수축 심각",
        "한쪽에 점들이 몰려있음 → 특정 환자군 계통적 편향",
        "η수축 > 30% 상태에서 IPRED vs DV가 좋아 보임 → 허상: 수축 때문에 IPRED ≈ PRED가 된 것",
      ],
      expert:"IPRED가 좋다고 모델이 좋은 것이 아니다. 파라미터가 많을수록 개별 피팅은 당연히 좋아진다(오버피팅). VPC가 IPRED vs DV 플롯보다 더 중요한 이유다.",
    },
    {
      name:"③ CWRES vs TIME", subtitle:"조건부 가중 잔차 vs 시간",
      color:C.red,
      what:"CWRES: Conditional Weighted Residual. η의 개인 차이를 조건화한 잔차. 이상적으로 평균 0, 분산 1을 따라야 한다. X축: 시간, Y축: CWRES.",
      ideal:"CWRES가 시간에 따라 무작위로 ±2~3 범위 내에 분포. 빨간 추세선이 y=0 수평선에 수렴.",
      bad:[
        "깔때기(Funnel) 모양 → 분산이 시간에 따라 증가 → 오차 모델(Proportional) 재검토",
        "S자 패턴(초기 음수, 중간 양수, 후기 음수 등) → 구조 모델 문제 (예: 2구획이 필요한데 1구획 사용)",
        "특정 시간대에서만 계통적 이탈 → 그 시간대에 해당하는 구조적 특징(흡수상, 분포상) 검토",
        "±3 범위 밖에 점이 많음 → 이상값(outlier) 또는 심각한 오차 모델 불일치",
      ],
      expert:"CWRES vs TIME의 '두께(분산)'가 시간에 따라 일정한지가 핵심이다. 분산이 커지면(분산이균질성, Heteroscedasticity) → 오차 모델 변경(예: Additive→Proportional 또는 Combined). 패턴이 생기면(비무작위성) → 구조 모델 변경이 필요하다. 이 두 가지 구분을 명확히 하는 것이 계량약리학 실력의 핵심이다.",
    },
    {
      name:"④ CWRES vs PRED", subtitle:"조건부 가중 잔차 vs 모집단 예측값",
      color:C.purple,
      what:"X축: PRED, Y축: CWRES. 농도 수준에 따라 잔차가 무작위인지 확인한다. CWRES vs TIME과 쌍으로 반드시 확인해야 한다.",
      ideal:"PRED 전 범위에서 CWRES가 ±2~3 내에 무작위 분포. 추세선이 y=0 수평.",
      bad:[
        "낮은 PRED에서 음수 CWRES, 높은 PRED에서 양수 CWRES(또는 반대) → 비선형 제거 가능성",
        "높은 PRED에서만 분산 증가 → 고농도 구간의 오차 모델 부적합",
        "저농도 구간에서 점이 없음 → LOQ(정량 하한) 이하 데이터 처리 방법 검토",
      ],
      expert:"CWRES vs PRED에서 V자 또는 역V자 패턴이 나타나면 가장 흔한 원인은 구획 수 부족이다. 1구획 모델로 2구획 약물을 설명할 때 분포상에서 음수 잔차, 소거상에서 양수 잔차(또는 반대)가 나타나 특징적인 패턴을 만든다. PRED의 특정 범위에서 계통적 편향을 발견했을 때 semilog C-t plot으로 돌아가서 biexponential 여부를 재검토하라.",
    },
  ];
  const p = plots[active];
  return <div>
    <Box title="GOF 4종 플롯 — 계량약리학자의 눈으로 보는 법" color={C.teal}>
      <div style={{fontSize:12, color:C.gray, lineHeight:1.7, marginBottom:10}}>
