          ["VPC","시뮬레이션이 실제 데이터 분포를 재현하는가","예측력 검증"],
          ["임상 실용성","너무 복잡한 모델은 실제 활용 불가. Parsimony 원칙","Occam의 면도날"],
        ]}
      />
    </Box>
  </div>;
}

// ── 5. ERROR MODELS ───────────────────────────────────────
function ErrorSection() {
  return <div>
    <Box title="잔차 오류 모델 — 측정 오류의 성격을 수식화한다" color={C.orange}>
      <div style={{marginBottom:10}}>
        잔차 오류 모델(Residual Error Model)은 관측값(y_obs)과 모델 예측값(IPRED) 사이의 차이를
        어떤 수학적 구조로 설명할 것인가를 결정한다.
        데이터의 오류 특성을 잘못 지정하면 파라미터 추정이 편향된다.
      </div>
      <CT headers={["모델명","수식","$ERROR 코드","σ² 의미","CV 특성","적합 데이터"]}
        colors={[C.orange, C.orange, C.orange, C.orange, C.orange, C.orange]}
        rows={[
          ["Additive",      "Y = IPRED + ε",                    "Y = F + EPS(1)",               "절대 오차 크기 (단위: 농도²)","CV = σ/μ (농도 의존)",       "PD 데이터, LOQ 근처 데이터"],
          ["Proportional\n(CV형)", "Y = IPRED × (1+ε)",         "Y = F*(1+EPS(1))",             "CV² (비례 오차 %²)",           "CV = √σ² = 일정",          "농도 범위 넓고 비례 오차 주도"],
          ["Combined ★실무","Y = IPRED×(1+ε₁) + ε₂",           "W=SQRT(θ₄²+θ₅²*F²)\nY=F+W*EPS(1)","θ₄=절대, θ₅=비례",             "저농도: 절대 주도\n고농도: 비례 주도","★대부분의 PK 데이터"],
          ["Log-additive",  "ln(Y) = ln(IPRED) + ε",           "Y = LOG(F) + EPS(1)",          "log-scale 오차",               "CV ≈ σ (log scale에서 일정)","log-transformed DV 사용 시"],
        ]}
      />
    </Box>

    <Box title="Combined 모델 하나로 3가지 모델 구현하기 — 실무 핵심 기술" color={C.orange}>
      <div style={{background:C.orangeL, borderRadius:8, padding:"10px 12px", marginBottom:10}}>
        <div style={{fontWeight:700, color:C.orange, marginBottom:6}}>Combined 모델의 W 공식</div>
        <div style={{fontFamily:"monospace", fontSize:12.5, lineHeight:2.2}}>
          <div>{"W = SQRT(θ₄² + θ₅² × F²)"}</div>
          <div>{"Y = F + W × EPS(1)        ; EPS(1) ~ N(0,1) FIX"}</div>
          <div style={{color:C.grayMid, fontSize:11}}>{"EPS(1)=1로 고정하고 실제 오차 크기를 θ₄, θ₅ (세타)로 추정"}</div>
        </div>
      </div>
      <CT headers={["원하는 모델","설정 방법","결과 W","비고"]}
        colors={[C.orange, C.orange, C.orange, C.amber]}
        rows={[
          ["★Combined","θ₄ > 0, θ₅ > 0 (둘 다 추정)",         "√(θ₄² + θ₅²×F²)","저농도: θ₄ 지배, 고농도: θ₅ 지배"],
          ["Additive만",  "θ₅ = 0 FIX",                        "θ₄",               "W는 상수"],
          ["Proportional만","θ₄ = 0 FIX",                      "θ₅ × F",           "W는 F에 비례"],
        ]}
      />
      <Code lines={[
        {c:"#94a3b8", t:"; Combined Error Model 표준 코드 ($ERROR 블록)"},
        {c:"#fbbf24", t:"$ERROR"},
        {c:"#86efac", t:"  W    = SQRT(THETA(4)**2 + THETA(5)**2 * F**2)"},
        {c:"#86efac", t:"  IPRED = F"},
        {c:"#86efac", t:"  IRES  = DV - IPRED                 ; Individual Residual"},
        {c:"#86efac", t:"  IWRES = IRES / W                   ; Individual Weighted Residual"},
        {c:"#86efac", t:"  Y     = F + W * EPS(1)             ; Combined error"},
        {c:"",        t:""},
        {c:"#fbbf24", t:"$SIGMA  1 FIX                        ; EPS ~ N(0,1), 고정"},
        {c:"#94a3b8", t:"; 실제 오차 크기는 THETA(4), THETA(5)에서 추정"},
        {c:"#94a3b8", t:"; THETA(4) = 0 FIX -> Proportional만"},
        {c:"#94a3b8", t:"; THETA(5) = 0 FIX -> Additive만"},
      ]}/>
      <Gem>{"$SIGMA = 1 FIX + EPS 사용 패턴: EPS 자체를 추정하지 않고 1로 고정한 뒤, 실제 오차 크기를 THETA(세타)로 추정하는 것이 실무 표준이다. 모델이 더 안정적으로 수렴하고 $THETA/$SIGMA 구분도 명확해진다."}</Gem>
    </Box>

    <Acc title="각 에러 모델에서 CV% 계산법" color={C.orange}>
      <Code lines={[
        {c:"#94a3b8", t:"; 에러 모델별 CV% 계산"},
        {c:"",        t:""},
        {c:"#fbbf24", t:"; 1. Additive (Y = F + EPS):"},
        {c:"#86efac", t:"   CV% = (sqrt(sigma²) / mean_conc) × 100"},
        {c:"#94a3b8", t:";   농도에 따라 CV%가 변화 (낮은 농도에서 CV% 높음)"},
        {c:"",        t:""},
        {c:"#fbbf24", t:"; 2. Proportional (Y = F×(1+EPS)):"},
        {c:"#86efac", t:"   CV% = sqrt(sigma²) × 100   <- 농도와 무관, 일정"},
        {c:"",        t:""},
        {c:"#fbbf24", t:"; 3. Combined (W 방식):"},
        {c:"#86efac", t:"   CV_add%  = (theta4 / mean_conc) × 100   ; 절대 오차 기여"},
        {c:"#86efac", t:"   CV_prop% = theta5 × 100                  ; 비례 오차 기여"},
        {c:"",        t:""},
        {c:"#94a3b8", t:"; 규제 보고 시: CV%로 보고하는 것이 표준."},
        {c:"#94a3b8", t:"; 'sigma²=0.04' 보다 'Proportional RUV: 20%'가 임상적으로 의미 있음"},
      ]}/>
    </Acc>
  </div>;
}

