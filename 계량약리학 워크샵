};

// ── 1. WHY ────────────────────────────────────────────────
function WhySection() {
  return <div>
    <Box title="계량약리학(Pharmacometrics)이란 무엇인가" color={C.blue}>
      <div style={{fontSize:13, fontWeight:800, color:C.blue, textAlign:"center", padding:"10px 0", background:C.blueL, borderRadius:8, marginBottom:12}}>
        {"\"약을 주고 나서 약효나 부작용을 얼마나 정량적으로 표현할 수 있는가를\n고민하다가 그 방법을 찾은 것이 계량약리학이다.\""}
      </div>
      <div style={{fontSize:12.5, lineHeight:1.85, marginBottom:10}}>
        Pharmacometrics = <strong>Pharmaco</strong>(약리학) + <strong>Metrics</strong>(측정·계량).
        한국어로는 <strong>계량약리학</strong>이라 정착되었다. 우리말에서 핵심 개념이 뒤에 오는 관례에 따라, '측정한다(Metrics)'는 의미가 '계량'으로, '약리학(Pharmaco)'이 뒤에 붙어 '계량약리학'이 된다.
      </div>
      <div style={{background:"#f8fafc", borderRadius:8, padding:"10px 14px", marginBottom:10, border:"1px solid #e2e8f0"}}>
        <div style={{fontWeight:700, color:C.slate, fontSize:12.5, marginBottom:6}}>계량약리학의 다양한 이름들 — 모두 같은 개념의 다른 표현</div>
        <div style={{display:"flex", flexWrap:"wrap", gap:6}}>
          {["Pharmacometrics","Population PK/PD","Mixed Effects Modeling","PKPD Modeling","Quantitative Pharmacology","Quantitative Clinical Pharmacology","Model-Based Drug Development (MBDD)","Model-Informed Drug Development (MIDD)"].map((n,i)=>(
            <span key={i} style={{background:C.blue+"15", color:C.blue, padding:"3px 9px", borderRadius:5, fontSize:11, fontWeight:600}}>{n}</span>
          ))}
        </div>
      </div>
      <Expert>{"이름이 많다는 것은 이 분야가 여러 방향에서 동시에 발달했다는 의미다. 통계학자는 'Mixed Effects Model'이라 부르고, 임상약리학자는 'Population PK/PD'라 부르고, 규제과학자는 'MIDD'라 부른다. 하지만 핵심은 하나다: 데이터와 수학적 모델을 결합하여 약물-인체 상호작용을 정량적으로 기술하고 예측한다. 어떤 이름으로 불리든 같은 도구상자를 사용한다."}</Expert>
    </Box>

    <Box title="왜 필요한가 — 임상시험의 한계와 계량약리학의 역할" color={C.blue}>
      <div style={{fontSize:12.5, lineHeight:1.75, marginBottom:10}}>
        모든 의문에 직접 임상시험으로 답할 수 있다면 계량약리학은 필요 없다. 그러나 현실은 세 가지 이유로 그것이 불가능하다.
      </div>
      <div style={{display:"flex", flexDirection:"column", gap:6, marginBottom:10}}>
        {[
          {icon:"💰", title:"비용과 시간", desc:"노인 환자, 소아 환자, 신장애 환자, 간장애 환자, 모든 가능한 용량 조합을 임상시험으로 다 검증하려면 수십 년과 수백억이 필요하다.", color:C.red},
          {icon:"⚖", title:"윤리적 한계", desc:"중증 환자에게 다양한 용량을 실험하거나, 소아에게 반복적인 채혈 연구를 하는 것은 윤리적으로 허용되지 않는 경우가 많다.", color:C.amber},
          {icon:"📊", title:"정보의 불충분성", desc:"임상시험을 해도 얻을 수 있는 데이터는 제한적이다. 스파스 샘플링(1~2개의 혈액 샘플)으로 개인별 PK를 추정해야 하는 현실.", color:C.purple},
        ].map((r,i)=>(
          <div key={i} style={{display:"flex", gap:10, padding:"9px 12px", background:r.color+"09", borderLeft:`3px solid ${r.color}`, borderRadius:"0 7px 7px 0"}}>
            <span style={{fontSize:18, lineHeight:1}}>{r.icon}</span>
            <div>
              <div style={{fontWeight:700, color:r.color, fontSize:12.5}}>{r.title}</div>
              <div style={{fontSize:12, color:C.gray, lineHeight:1.7}}>{r.desc}</div>
            </div>
          </div>
        ))}
      </div>
      <div style={{background:C.greenL, borderRadius:8, padding:"10px 12px"}}>
        <div style={{fontWeight:700, color:C.green, fontSize:12.5, marginBottom:4}}>✅ 계량약리학이 메꾸는 빈틈</div>
        <div style={{fontSize:12, color:C.gray, lineHeight:1.75}}>
          적은 수의 환자에서 얻은 제한된 데이터로 → 많은 환자군에서의 PK/PD 파라미터를 추정하고 → 직접 시험해보지 않은 용량·환자군·상황을 시뮬레이션으로 예측한다. 이것이 계량약리학이 1970년대 이후 FDA와 글로벌 제약기업에서 필수 도구로 자리잡은 이유다.
        </div>
      </div>
    </Box>

    <Box title="계량약리학의 역사적 맥락 — 왜 지금 배우는가" color={C.teal}>
      <CT headers={["시대","발전 내용","핵심 인물/사건"]}
        colors={[C.teal, C.slate, C.blue]}
        rows={[
          ["1970년대","Population PK 개념 태동. NONMEM 소프트웨어 개발 시작","Sheiner & Beal (UCSF). NONMEM 1.0 발표"],
          ["1980년대","FDA가 Population PK를 공식 인정. 희귀 환자군 분석 도입","FDA Guidance on Population PK (1999년 공식화)"],
          ["1990년대","PKPD 통합 모델링. Exposure-Response 규제 문서화","FDA E-R 가이던스. 시부트라민 등 PKPD 모델 사례"],
          ["2000년대","MIDD(Model-Informed Drug Development) 패러다임 확산","FDA Critical Path Initiative (2004). MIDD 가이던스"],
          ["2010년대 이후","AI/ML 융합. 베이지안 TDM. 디지털 트윈 개념","MID³ 콘소시엄. adaptive design 규제 수용"],
        ]}
      />
      <Gem>{"지금이 계량약리학을 배우기에 최적의 시점이다. 규제기관(FDA/EMA)이 MIDD를 공식적으로 요구하기 시작했고, AI/ML과의 융합이 급격히 진행 중이며, 임상약사 출신 계량약리학자에 대한 수요가 증가하고 있다. 약사의 배경은 PK/PD 기전에 대한 깊은 이해라는 '해자(Moat)'가 된다."}</Gem>
    </Box>
  </div>;
}

// ── 2. DOSE-EXPOSURE-RESPONSE ─────────────────────────────
function DoseSection() {
  return <div>
    <Box title="Dose → Exposure → Response — 계량약리학의 핵심 프레임워크" color={C.green}>
      <div style={{fontSize:12.5, lineHeight:1.75, marginBottom:12}}>
        계량약리학의 모든 것은 이 세 개의 연결 고리로 설명된다. 이 관계를 이해하면 모든 PKPD 모델의 구조가 이해된다.
      </div>
      <div style={{display:"flex", alignItems:"center", gap:4, marginBottom:16, flexWrap:"wrap"}}>
        {[
          {label:"Dose (용량)", sub:"투여량", color:C.blue, note:"우리가 조절하는 입력값"},
          {label:"→", color:"transparent"},
          {label:"PK", sub:"약동학", color:C.green, note:"Dose → Exposure 변환"},
          {label:"→", color:"transparent"},
          {label:"Exposure", sub:"노출(농도)", color:C.teal, note:"C(t), AUC, Cmax"},
          {label:"→", color:"transparent"},
          {label:"PD", sub:"약력학", color:C.purple, note:"Exposure → Response 변환"},
          {label:"→", color:"transparent"},
          {label:"Response", sub:"약효/독성", color:C.red, note:"임상적 결과"},
        ].map((b,i)=>(
          b.label==="→" ?
          <div key={i} style={{fontSize:20, fontWeight:900, color:C.grayMid}}>→</div> :
          <div key={i} style={{flex:1, minWidth:80, textAlign:"center", padding:"8px 6px", background:b.color+"15", border:`2px solid ${b.color}44`, borderRadius:8}}>
            <div style={{fontWeight:800, color:b.color, fontSize:12}}>{b.label}</div>
            <div style={{fontSize:10, color:C.grayMid}}>{b.sub}</div>
            <div style={{fontSize:9.5, color:b.color, marginTop:3}}>{b.note}</div>
          </div>
        ))}
      </div>
      <CT headers={["구간","학문 영역","핵심 질문","파라미터 예시"]}
        colors={[C.green, C.blue, C.slate, C.teal]}
        rows={[
          ["Dose → Exposure","약동학(PK)","같은 용량을 줬을 때 혈중 농도가 사람마다 왜 다른가?","CL, V, KA, t½, F(생체이용률)"],
          ["Exposure → Response","약력학(PD)","같은 혈중 농도에서 왜 약효가 사람마다 다른가?","Emax, EC50, Hill coefficient"],
          ["Disease Progression","질병 진행 모델","약 없이 질병은 어떻게 변하는가?","k_prog, baseline, 시간 함수"],
        ]}
      />
      <Expert>{"'Exposure'라는 용어가 왜 'Concentration'이 아닌가: 농도(Concentration)는 시간에 따라 변하는 값이다. '이 환자의 농도는 얼마인가?'라는 질문 자체가 불완전하다 — 어느 시점의 농도인가? AUC, Cmax, Cmin, 평균 농도 모두 다른 값이다. Exposure는 이 모든 시간적 변화를 통칭하는 개념이다. 따라서 'Exposure-Response'가 'Concentration-Response'보다 더 정확한 표현이다."}</Expert>
    </Box>

    <Box title="Dose-Response vs Exposure-Response — 왜 구분이 중요한가" color={C.green}>
      <div style={{display:"flex", gap:8, marginBottom:12}}>
        <div style={{flex:1, background:C.redL, borderRadius:8, padding:"10px 12px"}}>
          <div style={{fontWeight:800, color:C.red, fontSize:12, marginBottom:6}}>❌ Dose-Response만 보는 경우</div>
          <div style={{fontSize:12, color:C.gray, lineHeight:1.75}}>
            5mg을 주면 약효가 20%였다.<br/>
            10mg을 주면 두 배인 40%가 될까?<br/>
            → 꼭 그렇지 않다. 왜?<br/>
            <strong>같은 5mg이라도 사람마다 혈중 농도가 다르기 때문.</strong><br/>
            체중 50kg인 사람과 100kg인 사람의 Exposure는 다르다.
          </div>
        </div>
        <div style={{flex:1, background:C.greenL, borderRadius:8, padding:"10px 12px"}}>
          <div style={{fontWeight:800, color:C.green, fontSize:12, marginBottom:6}}>✅ Exposure-Response로 보는 경우</div>
          <div style={{fontSize:12, color:C.gray, lineHeight:1.75}}>
            Exposure(AUC)가 100 ng·h/mL일 때 약효 20%.<br/>
            Exposure가 200 ng·h/mL이면 약효 ?<br/>
            → E-R 곡선(Emax 모델)으로 정확히 예측 가능.<br/>
            <strong>이 관계는 용량이 달라도 환자군이 달라도 일관적이다.</strong>
          </div>
        </div>
      </div>
      <Clin>{"임상 실무에서 이 차이가 중요한 순간: 동일 용량인데 환자 A는 약효가 강하고 B는 약효가 없다 → Dose-Response 관점에서는 미스터리. Exposure-Response 관점에서는 → A의 CL이 낮아 AUC가 높고, B의 CL이 높아 AUC가 낮기 때문 → 용량 조정 근거 제시 가능. TDM(치료약물모니터링)이 바로 이 E-R 관계를 개인 수준에서 적용하는 것이다."}</Clin>
    </Box>
  </div>;
}

// ── 3. MODEL ──────────────────────────────────────────────
function ModelSection() {
  return <div>
    <Box title="모델의 본질 — '이상적인 곡선'과 '현실 데이터' 사이" color={C.purple}>
      <div style={{fontSize:12.5, lineHeight:1.75, marginBottom:10}}>
        모델이란 현실의 복잡성을 단순화한 수학적 표현이다. 완벽한 모델은 없다.
        하지만 좋은 모델은 '충분히 유용한(useful)' 예측을 제공한다.
        George Box의 유명한 말: "모든 모델은 틀렸다. 하지만 일부는 유용하다."
      </div>
      <div style={{display:"flex", gap:8, marginBottom:12}}>
        <div style={{flex:1, background:"#f0f4ff", borderRadius:8, padding:"10px 12px"}}>
          <div style={{fontWeight:800, color:C.blue, fontSize:12, marginBottom:6}}>현실 데이터 (관찰값)</div>
          <div style={{fontSize:12, color:C.gray, lineHeight:1.7}}>
            시간에 따라 측정된 혈중 농도 점들.<br/>
            측정 오차, 개인 간 차이로 '울퉁불퉁'하다.<br/>
            이것만으로는 패턴을 정확히 파악하기 어렵다.
          </div>
        </div>
        <div style={{flex:1, background:"#f0fdf4", borderRadius:8, padding:"10px 12px"}}>
          <div style={{fontWeight:800, color:C.green, fontSize:12, marginBottom:6}}>모델 (매끄러운 곡선)</div>
          <div style={{fontSize:12, color:C.gray, lineHeight:1.7}}>
            수식으로 표현된 '진실한 모습'.<br/>
            C(t) = (Dose/V) × exp(-CL/V × t)<br/>
            파라미터(CL, V)가 이 곡선의 모양을 결정한다.
          </div>
        </div>
      </div>
      <div style={{background:"#f8f0ff", borderRadius:8, padding:"10px 14px", marginBottom:10}}>
        <div style={{fontWeight:700, color:C.purple, fontSize:12.5, marginBottom:6}}>1-구획 IV 볼루스 모델 — 가장 기본적인 PK 모델</div>
        <div style={{fontFamily:"monospace", fontSize:12.5, lineHeight:2.2, color:C.slate}}>
          <div>{"A(t) = Dose × exp(-k × t)           // 체내 약물량"}</div>
          <div>{"C(t) = A(t) / Vd                    // 혈중 농도"}</div>
          <div>{"k    = CL / Vd                      // 소거 속도 상수"}</div>
          <div>{"t½   = 0.693 / k = 0.693 × Vd / CL // 반감기"}</div>
        </div>
        <div style={{fontSize:11.5, color:C.grayMid, marginTop:6, lineHeight:1.7}}>
          알고 있는 것: Dose(투여량), t(시간), C(t)(관찰된 농도)<br/>
          모르는 것(파라미터): Vd(분포 용적), CL(청소율)<br/>
          모델링 = 알고 있는 것으로 모르는 것을 추정하는 과정
        </div>
      </div>
      <Expert>{"'파라미터를 찾는다'는 것의 본질: 우리는 수백 가지 CL, V 조합을 컴퓨터에 입력해서 각 조합이 만드는 곡선과 실제 관찰값의 차이(에러)를 계산하고, 그 에러가 가장 적은 조합을 찾는다. 이것이 Least Squares(최소제곱법)이다. NONMEM이 하는 일의 본질도 이것이다 — 수학적으로 더 정교한 방법(FOCE, Laplace)을 쓰지만 개념적으로는 동일하다."}</Expert>
    </Box>

    <Box title="파라미터의 종류 — 무엇을 찾으려고 하는가" color={C.purple}>
      <CT headers={["파라미터 유형","약칭","예시","의미"]}
        colors={[C.purple, C.slate, C.green, C.blue]}
        rows={[
          ["청소율 (Clearance)","CL","10 L/h","단위시간당 약물이 완전히 제거되는 혈액량. 신장·간 기능에 의존"],
          ["분포 용적 (Volume of Distribution)","Vd 또는 V","50 L","체내 약물이 분포하는 '가상의 용적'. 친지질성 약물은 Vd 매우 큼"],
          ["흡수 속도 상수","KA","0.5 /h","경구 투여 후 약물이 혈류로 흡수되는 속도"],
          ["최대 약효","Emax","100%","이론적으로 얻을 수 있는 최대 약리효과"],
          ["EC50","EC50","10 ng/mL","Emax의 50%를 달성하는 농도. 약물 감수성의 지표"],
          ["Hill 계수 (협력도)","γ","2","S자형 E-R 곡선의 가파름. γ>1이면 급격한 전환"],
        ]}
      />
      <Warn c={C.amber}>{"파라미터는 단순한 숫자가 아니다. 각 파라미터에는 생물학적 의미가 있다. CL이 크다는 것은 약물이 빠르게 체내에서 제거됨을 의미하고, 신기능이나 간기능과 연결된다. Vd가 크다는 것은 약물이 조직에 광범위하게 분포함을 의미한다. 파라미터 값을 해석할 때는 항상 그 생물학적 의미를 먼저 묻는 습관을 가져야 한다."}</Warn>
    </Box>
  </div>;
}

