// ── 5. ADVAN9 ────────────────────────────────────────────
function Advan9Section() {
  return <div>
    <Box title="ADVAN9 — ADVAN6의 대안, 그러나 실무에서 드물게 사용" color={C.green}>
      <div style={{marginBottom:10}}>
        ADVAN9는 General Nonlinear ADVAN으로, ADVAN6과 거의 동일한 상황에서 사용할 수 있다.
        문법도 거의 같고 $DES도 필요하며 TOL도 필요하다.
        핵심 차이는 ODE를 $DES(differential equations) 대신 <strong>$AES(algebraic equations)로도 쓸 수 있다</strong>는 점이다.
      </div>
      <CT headers={["비교 항목","ADVAN6","ADVAN9"]}
        colors={[C.slate, C.blue, C.green]}
        rows={[
          ["ODE Solver", "Runge-Kutta 4th order", "Adams-Bashforth/Gear (주장: 더 robust)"],
          ["$DES 블록",  "★필수",                 "가능 ($DES 또는 $AES 선택)"],
          ["$AES 블록",  "없음",                   "★추가 가능 (Algebraic Equations)"],
          ["속도",       "빠름 (대부분)",           "상황별 다름"],
          ["실무 사용",  "★★★★★ (가장 흔함)",   "★★☆☆☆ (드묾)"],
          ["선택 기준", "일반적인 비선형 PK/PD",   "ADVAN6 수렴 어려울 때 시험적 대안"],
        ]}
      />
      <Warn>{"Holford 교수 제안: $ESTIMATION 에서 MAXEVAL=0으로 설정하고 ADVAN6과 ADVAN9를 각각 실행해서 계산 시간이 짧은 것을 선택하라. 어떤 것이 더 나은지는 데이터와 모델에 따라 달라진다."}</Warn>
      <Box title="$AES 블록 — ADVAN9의 특수 기능" color={C.green}>
        <div style={{fontSize:12.5, lineHeight:1.75, marginBottom:8}}>
          $AES는 "Algebraic Equations"의 약자로, 미분방정식이 아닌 <strong>대수 방정식(닫힌 형태 해)</strong>을
          직접 쓸 수 있는 블록이다. 예를 들어 QSS(Quasi-Steady-State) TMDD에서
          수용체 점유율을 이차방정식으로 표현할 때 유용하다.
        </div>
        <Code lines={[
          {c:"#94a3b8", t:"; ADVAN9 $AES 사용 예 — QSS TMDD의 algebraic solution"},
          {c:"#86efac", t:"$AES"},
          {c:"#86efac", t:"  ; QSS 근사: L(자유 약물)을 이차방정식으로 직접 계산"},
          {c:"#86efac", t:"  LTOT = A(1) / V1              ; 총 약물 농도"},
          {c:"#86efac", t:"  RTOT = A(2)                   ; 총 수용체 양"},
          {c:"#86efac", t:"  KSS  = (koff + kint) / kon    ; 준정상상태 상수"},
          {c:"#86efac", t:"  DISC = (LTOT - RTOT - KSS)**2 + 4*KSS*LTOT"},
          {c:"#86efac", t:"  L    = 0.5 * (LTOT - RTOT - KSS + SQRT(DISC)) ; 이차방정식 해"},
        ]}/>
      </Box>
    </Box>
  </div>;
}

// ── 6. ADVAN13 ────────────────────────────────────────────
